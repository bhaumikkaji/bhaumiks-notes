---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  category?: string;
  image?: string;
}

const { title, description, pubDate, category, image } = Astro.props;
---

<BaseLayout title={title} description={description} image={image} type="article">
  <article class="note">
    <header class="note-header">
      <h1 class="note-title">{title}</h1>
      {category && (
        <span class="note-category">{category}</span>
      )}
    </header>
    <div class="note-body">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .note-header {
    margin-bottom: 40px;
  }

  .note-title {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 8px;
  }

  .note-category {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: var(--color-tag-bg);
    padding: 3px 10px;
    border-radius: 12px;
  }

  .note-body {
    font-size: 17px;
    line-height: 1.75;
  }

  .note-body :global(h2) {
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-top: 2.5em;
    margin-bottom: 0.75em;
  }

  .note-body :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 2em;
    margin-bottom: 0.5em;
  }

  .note-body :global(p) {
    margin-bottom: 1.25em;
  }

  .note-body :global(strong) {
    font-weight: 600;
  }

  .note-body :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .note-body :global(a:hover) {
    text-decoration: underline;
  }

  .note-body :global(blockquote) {
    border-left: 3px solid var(--color-border);
    padding-left: 16px;
    color: var(--color-text-secondary);
    margin: 1.5em 0;
    font-style: italic;
  }

  .note-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-tag-bg);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .note-body :global(pre) {
    background: var(--color-tag-bg);
    padding: 16px;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5em 0;
    font-size: 14px;
  }

  .note-body :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
  }

  .note-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2em 0;
  }

  .note-body :global(ul),
  .note-body :global(ol) {
    margin-bottom: 1.25em;
    padding-left: 1.5em;
  }

  .note-body :global(li) {
    margin-bottom: 0.4em;
  }

  .note-body :global(img) {
    max-width: 100%;
    border-radius: 8px;
    margin: 1.5em 0;
  }

  @media (max-width: 640px) {
    .note-title {
      font-size: 1.6rem;
    }
  }
</style>