---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import Reactions from '../components/Reactions.astro';
import AudioPlayer from '../components/AudioPlayer.astro';

export interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  category?: string | string[];
  image?: string;
  slug?: string;
  tldr?: string;
  audio?: string;
}

const { title, description, pubDate, category, image, slug = '', tldr, audio } = Astro.props;

// JSON-LD structured data
const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description || '',
  url: `https://notes.bhaumikkaji.com/notes/${slug}/`,
  image: image ? `https://notes.bhaumikkaji.com${image}` : 'https://notes.bhaumikkaji.com/images/og-default.jpg',
  datePublished: pubDate?.toISOString(),
  dateModified: pubDate?.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Bhaumik Kalpesh Kaji',
    url: 'https://notes.bhaumikkaji.com',
    image: 'https://notes.bhaumikkaji.com/images/profile.jpg',
  },
  publisher: {
    '@type': 'Organization',
    name: "Bhaumik's Notes",
    logo: {
      '@type': 'ImageObject',
      url: 'https://notes.bhaumikkaji.com/images/profile.jpg',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://notes.bhaumikkaji.com/notes/${slug}/`,
  },
  ...(category ? { keywords: Array.isArray(category) ? category.join(', ') : category } : {}),
};
---

<BaseLayout title={title} description={description} image={image} type="article">
  <article class="note">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <div class="note-layout">
      <aside class="note-sidebar">
        <TableOfContents />
      </aside>
      <div class="note-body" id="note-body">
        {category && (
          <span class="note-category">
            {Array.isArray(category) ? category[0] : category}
          </span>
        )}
        <h1 class="note-title">{title}</h1>
        <div class="toc-mobile">
          <TableOfContents />
        </div>
        {tldr && (
          <>
            <details class="tldr" id="tldr">
              <summary>
                <span class="tldr-label">TL;DR</span>
              </summary>
              <div class="tldr-body">
                {audio && <AudioPlayer src={audio} />}
                {tldr}
              </div>
            </details>
            <hr />
          </>
        )}
        <div class="stream-content content-loading" id="stream-content">
          <slot />
        </div>
        <Reactions slug={slug} />
      </div>
    </div>
  </article>

  <script is:inline>
    (function() {
      function init() {
        const container = document.getElementById('stream-content');
        if (!container) return;

        // Skip heavy animation on touch devices (mobile) — go straight to visible
        const isTouchDevice = window.matchMedia('(pointer: coarse)').matches;
        if (isTouchDevice) {
          container.classList.remove('content-loading');
          return;
        }

        const WORD_DELAY = 25;
        const UNBLUR_DURATION = 350;

        // Step 1: Wrap all text into word spans
        const walker = document.createTreeWalker(container, NodeFilter.SHOW_TEXT, null, false);
        const textNodes = [];
        let node;
        while (node = walker.nextNode()) {
          if (node.textContent.trim()) textNodes.push(node);
        }

        textNodes.forEach(textNode => {
          const parent = textNode.parentNode;
          const text = textNode.textContent;
          const words = text.split(/(\s+)/);
          const fragment = document.createDocumentFragment();

          words.forEach(word => {
            if (word.trim() === '') {
              fragment.appendChild(document.createTextNode(word));
            } else {
              const span = document.createElement('span');
              span.className = 'stream-word';
              span.textContent = word;
              span.style.opacity = '0';
              span.style.filter = 'blur(6px)';
              span.style.transition = `opacity ${UNBLUR_DURATION}ms cubic-bezier(0.16,1,0.3,1), filter ${UNBLUR_DURATION}ms cubic-bezier(0.16,1,0.3,1)`;
              span.style.display = 'inline-block';
              span.style.willChange = 'opacity, filter';
              fragment.appendChild(span);
            }
          });

          parent.replaceChild(fragment, textNode);
        });

        // Step 2: Collect ALL animatable elements in DOM order
        // — words AND media (img, hr, pre, blockquote, ul, ol, table)
        const animatables = [];
        const allEls = container.querySelectorAll('*');

        allEls.forEach(el => {
          // Words
          if (el.classList.contains('stream-word')) {
            animatables.push({ type: 'word', el });
          }
          // Media / block elements that aren't containers for words
          else if (
            el.tagName === 'IMG' ||
            el.tagName === 'HR' ||
            el.tagName === 'PRE' ||
            el.tagName === 'TABLE' ||
            el.tagName === 'BLOCKQUOTE' ||
            (el.tagName === 'UL' && !el.querySelector('.stream-word')) ||
            (el.tagName === 'OL' && !el.querySelector('.stream-word'))
          ) {
            // Only add if not already inside a blockquote/pre/table we added
            const parentAdded = el.closest('blockquote[data-stream], pre[data-stream], table[data-stream]');
            if (!parentAdded) {
              el.dataset.stream = 'true';
              el.style.opacity = '0';
              el.style.filter = 'blur(8px)';
              el.style.transform = 'translateY(12px)';
              el.style.transition = `opacity ${UNBLUR_DURATION}ms cubic-bezier(0.16,1,0.3,1), filter ${UNBLUR_DURATION}ms cubic-bezier(0.16,1,0.3,1), transform ${UNBLUR_DURATION}ms cubic-bezier(0.16,1,0.3,1)`;
              el.style.willChange = 'opacity, filter, transform';
              animatables.push({ type: 'media', el });
            }
          }
        });

        // Step 3: Determine above-fold cutoff
        const viewportHeight = window.innerHeight;
        const firstBelowFold = animatables.findIndex(item => {
          const rect = item.el.getBoundingClientRect();
          return rect.top > viewportHeight - 50;
        });

        const cutoff = firstBelowFold > 0 ? firstBelowFold : 0;

        // Reveal above fold immediately
        for (let i = 0; i < cutoff; i++) {
          revealItem(animatables[i]);
        }

        // Step 4: Animate below fold
        let currentIndex = cutoff;
        let revealInterval = null;

        function revealItem(item) {
          item.el.style.opacity = '1';
          item.el.style.filter = 'blur(0px)';
          item.el.style.transform = 'translateY(0)';
        }

        function revealBatch() {
          if (currentIndex >= animatables.length) {
            clearInterval(revealInterval);
            revealInterval = null;
            return;
          }

          const batchSize = 3;
          for (let i = 0; i < batchSize && currentIndex < animatables.length; i++) {
            revealItem(animatables[currentIndex]);
            currentIndex++;
          }
        }

        // Scroll starts the animation
        let scrollTimeout;
        window.addEventListener('scroll', () => {
          if (!revealInterval) {
            revealInterval = setInterval(revealBatch, WORD_DELAY);
          }
          clearTimeout(scrollTimeout);
          scrollTimeout = setTimeout(() => { isScrolling = false; }, 150);
        }, { passive: true });

        // TOC click → jump and reveal from that section
        window.addEventListener('click', (e) => {
          const link = e.target.closest('a[href^="#"]');
          if (!link) return;
          const hash = link.getAttribute('href');
          if (!hash || hash === '#') return;
          const target = document.querySelector(hash);
          if (!target) return;

          // Find first animatable after this heading
          let found = false;
          for (let i = 0; i < animatables.length; i++) {
            const pos = target.compareDocumentPosition(animatables[i].el);
            if (pos & Node.DOCUMENT_POSITION_FOLLOWING) {
              currentIndex = i;
              found = true;
              break;
            }
          }

          if (found && !revealInterval) {
            revealInterval = setInterval(revealBatch, WORD_DELAY);
          }
        });

        // Already below fold on load
        if (cutoff < animatables.length && window.scrollY > 50) {
          revealInterval = setInterval(revealBatch, WORD_DELAY);
        }

        // Remove loading class — content is ready
        container.classList.remove('content-loading');
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }

      // Privacy-focused analytics — no cookies, no IP, no personal data
      (function() {
        var API_BASE = 'https://func-bhaumik-notes.azurewebsites.net/api/analytics';
        var slug = document.querySelector('article')?.dataset?.slug;
        if (!slug) {
          var match = location.pathname.match(/\/notes\/([^\/]+)\//);
          if (match) slug = match[1];
        }
        var isNotePage = !!slug;
        var sessionId = Math.random().toString(36).slice(2, 15) + Date.now().toString(36);
        var startTime = Date.now();
        var sentEvents = {};

        function track(event, metadata) {
          if (sentEvents[event]) return; // Don't double-send
          sentEvents[event] = true;
          fetch(API_BASE, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              slug: slug || 'site',
              event: event,
              sessionId: sessionId,
              metadata: metadata || {},
            }),
            credentials: 'omit',
          }).catch(function() {});
        }

        // Page view (after 3s engagement)
        setTimeout(function() {
          track('pageview', { path: location.pathname });
        }, 3000);

        // Track time on page (heartbeat every 30s)
        var heartbeatInterval = setInterval(function() {
          var elapsed = Math.round((Date.now() - startTime) / 1000);
          if (elapsed > 30) {
            track('time_heartbeat', { duration: elapsed });
          }
        }, 30000);

        // Scroll depth tracking
        var maxScroll = 0;
        var scrollSent = false;
        function checkScroll() {
          if (scrollSent) return;
          var docHeight = document.documentElement.scrollHeight - window.innerHeight;
          if (docHeight <= 0) return;
          var scrollPercent = window.scrollY / docHeight;
          if (scrollPercent > maxScroll) maxScroll = scrollPercent;

          if (scrollPercent >= 0.25 && !sentEvents['scroll_25']) {
            track('scroll_25');
          }
          if (scrollPercent >= 0.50 && !sentEvents['scroll_50']) {
            track('scroll_50');
          }
          if (scrollPercent >= 0.75 && !sentEvents['scroll_75']) {
            track('scroll_75');
            scrollSent = true;
          }
        }
        window.addEventListener('scroll', checkScroll, { passive: true });

        // TOC clicks
        document.querySelectorAll('.toc a, .toc-mobile a').forEach(function(link) {
          link.addEventListener('click', function() {
            track('toc_click', { target: link.getAttribute('href') });
          });
        });

        // Audio plays (TL;DR)
        document.querySelectorAll('.audio-widget button, audio').forEach(function(el) {
          el.addEventListener('play', function() {
            track('audio_play', { slug: slug });
          });
          // Also catch clicks on play buttons
          el.addEventListener('click', function() {
            if (el.tagName === 'BUTTON' || el.closest('.audio-widget')) {
              track('audio_play', { slug: slug });
            }
          });
        });

        // Resources page clicks
        if (location.pathname === '/resources/') {
          document.querySelectorAll('a[href^="http"]').forEach(function(link) {
            link.addEventListener('click', function() {
              track('resource_click', { url: link.href });
            });
          });
        }

        // Footer link clicks
        document.querySelectorAll('footer a').forEach(function(link) {
          link.addEventListener('click', function() {
            track('footer_click', { url: link.href, text: link.textContent });
          });
        });

        // Site exit tracking
        window.addEventListener('beforeunload', function() {
          var elapsed = Math.round((Date.now() - startTime) / 1000);
          // Send beacon for exit (best effort)
          if (navigator.sendBeacon) {
            navigator.sendBeacon(API_BASE, JSON.stringify({
              slug: slug || 'site',
              event: 'site_exit',
              sessionId: sessionId,
              metadata: { duration: elapsed, maxScroll: Math.round(maxScroll * 100) },
            }));
          }
          clearInterval(heartbeatInterval);
        });
      })();
    })();
  </script>
</BaseLayout>

<style>
  .note-category {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 12px;
    margin-bottom: 16px;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .note-title {
    font-size: 2.9rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin-bottom: 40px;
  }

  /* Two-column layout: TOC sidebar + content */
  .note-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 48px;
    align-items: start;
  }

  /* Collapse to single column when TOC is absent */
  .note-layout.no-toc {
    grid-template-columns: 1fr;
  }

  /* Collapse to single column when TOC is absent */
  .note-layout.no-toc {
    grid-template-columns: 1fr;
  }

  .note-sidebar {
    align-self: stretch;
  }

  .note-body {
    min-width: 0;
  }

  .note-body :global(h2) {
    scroll-margin-top: 80px;
  }

  .note-body :global(h3) {
    scroll-margin-top: 80px;
  }

  .note-body {
    font-size: 1.18rem;
    line-height: 1.75;
  }

  .note-body :global(h2) {
    font-size: 1.72rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-top: 2.5em;
    margin-bottom: 0.75em;
    line-height: 1.3;
  }

  .note-body :global(h3) {
    font-size: 1.36rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-top: 2em;
    margin-bottom: 0.5em;
  }

  .note-body :global(p) {
    margin-bottom: 1.25em;
  }

  .note-body :global(strong) {
    font-weight: 600;
  }

  .note-body :global(a) {
    color: var(--accent);
    text-decoration: none;
    text-decoration-line: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
    text-decoration-color: color-mix(in srgb, var(--accent) 40%, transparent);
    transition: text-decoration-color 0.15s ease, color 0.15s ease;
  }

  .note-body :global(a:hover) {
    text-decoration-color: var(--accent);
  }

  .note-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 12px 0 12px 20px;
    margin: 1.5em 0;
    color: var(--text-secondary);
    font-style: normal;
    font-size: 1.27rem;
    line-height: 1.65;
  }

  .note-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: color-mix(in srgb, var(--text-primary) 6%, transparent);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .note-body :global(pre) {
    background: color-mix(in srgb, var(--text-primary) 4%, transparent);
    border: 1px solid var(--border);
    padding: 20px;
    border-radius: 10px;
    overflow-x: auto;
    margin: 1.5em 0;
    font-size: 1rem;
    line-height: 1.6;
  }

  .note-body :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  .note-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2em 0;
  }

  .note-body :global(ul),
  .note-body :global(ol) {
    margin-bottom: 1.25em;
    padding-left: 1.5em;
  }

  .note-body :global(li) {
    margin-bottom: 0.4em;
  }

  .note-body :global(img) {
    max-width: 100%;
    border-radius: 10px;
    margin: 1.5em 0;
    border: 1px solid var(--border);
  }

  .note-body :global(iframe) {
    max-width: 100%;
    border-radius: 10px;
    margin: 1.5em 0;
  }

  @media (max-width: 1024px) {
    .note-layout,
    .note-layout.no-toc {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .note-sidebar {
      display: none;
    }

    .toc-mobile {
      margin-bottom: 1.5em;
      text-align: left;
    }

    .toc-mobile .toc {
      position: static;
      top: auto;
      padding-left: 0;
      max-height: none;
      overflow-y: visible;
    }

    .toc-mobile .toc-label {
      font-size: 0.75rem;
      margin-bottom: 8px;
    }

    .toc-mobile .toc-chapter {
      font-size: 0.85rem;
      padding: 4px 0;
    }

    .toc-mobile .toc-children {
      padding-left: 16px;
    }

    .toc-mobile .toc-children a {
      font-size: 0.78rem;
      padding: 2px 0;
    }
  }

  @media (min-width: 1025px) {
    .toc-mobile {
      display: none;
    }
  }

  /* Force show TOC in mobile container */
  @media (max-width: 1024px) {
    .toc-mobile .toc {
      display: block !important;
    }
  }

  @media (max-width: 640px) {
    .note-title {
      font-size: 2.27rem;
    }
  }

  .content-loading {
    opacity: 0;
  }

  #stream-content:not(.content-loading) {
    opacity: 1;
    transition: opacity 0.2s ease;
  }
</style>