---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import Reactions from '../components/Reactions.astro';

export interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  category?: string | string[];
  image?: string;
  slug?: string;
}

const { title, description, pubDate, category, image, slug = '' } = Astro.props;
---

<BaseLayout title={title} description={description} image={image} type="article">
  <article class="note">
    <div class="note-layout">
      <aside class="note-sidebar">
        <TableOfContents />
      </aside>
      <div class="note-body" id="note-body">
        {category && (
          <span class="note-category">
            {Array.isArray(category) ? category[0] : category}
          </span>
        )}
        <h1 class="note-title">{title}</h1>
        <div class="stream-content" id="stream-content">
          <slot />
        </div>
        <Reactions slug={slug} />
      </div>
    </div>
  </article>

  <script is:inline>
    (function() {
      const BASE_SPEED = 3; // ms per char — fast
      const JUMBLE_COUNT = 2; // random chars before landing
      const JUMBLE_SPEED = 25; // ms per jumble frame
      
      function init() {
        const container = document.getElementById('stream-content');
        if (!container) return;
        
        // Collect all text nodes in DOM order
        const walker = document.createTreeWalker(container, NodeFilter.SHOW_TEXT, null, false);
        const textNodes = [];
        let node;
        while (node = walker.nextNode()) {
          if (node.textContent.trim()) {
            textNodes.push(node);
          }
        }
        
        // Wrap each text node in spans for character-level control
        const charSpans = [];
        textNodes.forEach(textNode => {
          const parent = textNode.parentNode;
          const text = textNode.textContent;
          const fragment = document.createDocumentFragment();
          
          for (let i = 0; i < text.length; i++) {
            const span = document.createElement('span');
            span.className = 'stream-char';
            span.textContent = text[i];
            span.dataset.char = text[i]; // Store the real character
            span.style.opacity = '0';
            fragment.appendChild(span);
            charSpans.push(span);
          }
          
          parent.replaceChild(fragment, textNode);
        });
        
        // Mark all parent blocks as hidden initially
        const blocks = container.querySelectorAll('h2, h3, p, li, blockquote, pre, ul, ol, hr, img');
        blocks.forEach(block => {
          block.classList.add('stream-block');
        });
        
        let currentIndex = 0;
        let isTyping = false;
        
        function revealBlockForChar(span) {
          // Find the nearest parent block and reveal it
          let el = span;
          while (el && el !== container) {
            if (el.classList && el.classList.contains('stream-block')) {
              if (!el.classList.contains('stream-visible')) {
                el.classList.add('stream-visible');
              }
              break;
            }
            el = el.parentNode;
          }
        }
        
        function typeNext() {
          if (currentIndex >= charSpans.length) {
            isTyping = false;
            document.querySelector('.stream-cursor')?.remove();
            return;
          }
          
          const span = charSpans[currentIndex];
          const realChar = span.dataset.char;
          
          revealBlockForChar(span);
          
          // Mini unjumble: show random chars first, then land
          let jumbleStep = 0;
          const jumbleInterval = setInterval(() => {
            if (jumbleStep < JUMBLE_COUNT) {
              span.textContent = Math.random() > 0.5 
                ? String.fromCharCode(33 + Math.floor(Math.random() * 94))
                : realChar;
              span.style.opacity = '1';
              jumbleStep++;
            } else {
              clearInterval(jumbleInterval);
              span.textContent = realChar;
              span.style.opacity = '1';
              
              // Move cursor
              let cursor = document.querySelector('.stream-cursor');
              if (!cursor) {
                cursor = document.createElement('span');
                cursor.className = 'stream-cursor';
                cursor.textContent = '';
              }
              span.parentNode.insertBefore(cursor, span.nextSibling);
              
              currentIndex++;
              setTimeout(typeNext, BASE_SPEED);
            }
          }, JUMBLE_SPEED);
        }
        
        // Start typing after a short delay
        setTimeout(() => {
          isTyping = true;
          typeNext();
        }, 300);
      }
      
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
</BaseLayout>

<style>
  .note-category {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 12px;
    margin-bottom: 16px;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .note-title {
    font-size: 2.9rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin-bottom: 40px;
  }

  /* Stream effect */
  .stream-content .stream-block {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .stream-content .stream-block.stream-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .stream-char {
    transition: opacity 0.05s ease;
  }

  .stream-cursor {
    display: inline-block;
    width: 2px;
    height: 1.1em;
    background: var(--accent);
    margin-left: 1px;
    vertical-align: text-bottom;
    animation: stream-blink 0.8s step-end infinite;
    opacity: 0.8;
  }

  @keyframes stream-blink {
    0%, 100% { opacity: 0.8; }
    50% { opacity: 0; }
  }

  /* Two-column layout: TOC sidebar + content */
  .note-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 48px;
    align-items: start;
  }

  .note-sidebar {
    align-self: stretch;
  }

  .note-body {
    min-width: 0;
  }

  .note-body :global(h2) {
    scroll-margin-top: 80px;
  }

  .note-body :global(h3) {
    scroll-margin-top: 80px;
  }

  .note-body {
    font-size: 1.18rem;
    line-height: 1.75;
  }

  .note-body :global(h2) {
    font-size: 1.72rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-top: 2.5em;
    margin-bottom: 0.75em;
    line-height: 1.3;
  }

  .note-body :global(h3) {
    font-size: 1.36rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-top: 2em;
    margin-bottom: 0.5em;
  }

  .note-body :global(p) {
    margin-bottom: 1.25em;
  }

  .note-body :global(strong) {
    font-weight: 600;
  }

  .note-body :global(a) {
    color: var(--accent);
    text-decoration: none;
    text-decoration-line: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
    text-decoration-color: color-mix(in srgb, var(--accent) 40%, transparent);
    transition: text-decoration-color 0.15s ease, color 0.15s ease;
  }

  .note-body :global(a:hover) {
    text-decoration-color: var(--accent);
  }

  .note-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 12px 0 12px 20px;
    margin: 1.5em 0;
    color: var(--text-secondary);
    font-style: normal;
    font-size: 1.27rem;
    line-height: 1.65;
  }

  .note-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: color-mix(in srgb, var(--text-primary) 6%, transparent);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .note-body :global(pre) {
    background: color-mix(in srgb, var(--text-primary) 4%, transparent);
    border: 1px solid var(--border);
    padding: 20px;
    border-radius: 10px;
    overflow-x: auto;
    margin: 1.5em 0;
    font-size: 1rem;
    line-height: 1.6;
  }

  .note-body :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  .note-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2em 0;
  }

  .note-body :global(ul),
  .note-body :global(ol) {
    margin-bottom: 1.25em;
    padding-left: 1.5em;
  }

  .note-body :global(li) {
    margin-bottom: 0.4em;
  }

  .note-body :global(img) {
    max-width: 100%;
    border-radius: 10px;
    margin: 1.5em 0;
    border: 1px solid var(--border);
  }

  .note-body :global(iframe) {
    max-width: 100%;
    border-radius: 10px;
    margin: 1.5em 0;
  }

  @media (max-width: 1024px) {
    .note-layout {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .note-sidebar {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .note-title {
      font-size: 2.27rem;
    }
  }
</style>