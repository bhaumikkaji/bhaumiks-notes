---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import Reactions from '../components/Reactions.astro';

export interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  category?: string | string[];
  image?: string;
  slug?: string;
}

const { title, description, pubDate, category, image, slug = '' } = Astro.props;
---

<BaseLayout title={title} description={description} image={image} type="article">
  <article class="note">
    <div class="note-layout">
      <aside class="note-sidebar">
        <TableOfContents />
      </aside>
      <div class="note-body">
        {category && (
          <span class="note-category">
            {Array.isArray(category) ? category[0] : category}
          </span>
        )}
        <h1 class="note-title">{title}</h1>
        <slot />
        <Reactions slug={slug} />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .note-category {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 12px;
    margin-bottom: 16px;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .note-title {
    font-size: 2.9rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin-bottom: 40px;
  }

  /* Two-column layout: TOC sidebar + content */
  .note-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 48px;
    align-items: start;
  }

  .note-sidebar {
    /* Stretch to match content column height so sticky works */
    align-self: stretch;
  }

  .note-body {
    min-width: 0; /* prevent grid blowout */
  }

  .note-body :global(h2) {
    scroll-margin-top: 80px;
  }

  .note-body :global(h3) {
    scroll-margin-top: 80px;
  }

  .note-body {
    font-size: 1.18rem;
    line-height: 1.75;
  }

  .note-body :global(h2) {
    font-size: 1.72rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-top: 2.5em;
    margin-bottom: 0.75em;
    line-height: 1.3;
  }

  .note-body :global(h3) {
    font-size: 1.36rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-top: 2em;
    margin-bottom: 0.5em;
  }

  .note-body :global(p) {
    margin-bottom: 1.25em;
  }

  .note-body :global(strong) {
    font-weight: 600;
  }

  .note-body :global(a) {
    color: var(--accent);
    text-decoration: none;
    text-decoration-line: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
    text-decoration-color: color-mix(in srgb, var(--accent) 40%, transparent);
    transition: text-decoration-color 0.15s ease, color 0.15s ease;
  }

  .note-body :global(a:hover) {
    text-decoration-color: var(--accent);
  }

  .note-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 12px 0 12px 20px;
    margin: 1.5em 0;
    color: var(--text-secondary);
    font-style: normal;
    font-size: 1.27rem;
    line-height: 1.65;
  }

  .note-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: color-mix(in srgb, var(--text-primary) 6%, transparent);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .note-body :global(pre) {
    background: color-mix(in srgb, var(--text-primary) 4%, transparent);
    border: 1px solid var(--border);
    padding: 20px;
    border-radius: 10px;
    overflow-x: auto;
    margin: 1.5em 0;
    font-size: 1rem;
    line-height: 1.6;
  }

  .note-body :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  .note-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2em 0;
  }

  .note-body :global(ul),
  .note-body :global(ol) {
    margin-bottom: 1.25em;
    padding-left: 1.5em;
  }

  .note-body :global(li) {
    margin-bottom: 0.4em;
  }

  .note-body :global(img) {
    max-width: 100%;
    border-radius: 10px;
    margin: 1.5em 0;
    border: 1px solid var(--border);
  }

  .note-body :global(iframe) {
    max-width: 100%;
    border-radius: 10px;
    margin: 1.5em 0;
  }

  /* Responsive — collapse sidebar on tablet and below */
  @media (max-width: 1024px) {
    .note-layout {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .note-sidebar {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .note-title {
      font-size: 2.27rem;
    }
  }
</style>