---
import Personalize from '../components/Personalize.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  showScrollProgress?: boolean;
}

const { title, description = 'Notes on tech, design, and AI by Bhaumik Kaji.', image = '/images/og-default.svg', type = 'website', showScrollProgress = true } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" data-mode="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#1a1a1a" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />
    <meta name="author" content="Bhaumik Kaji" />
    <meta name="robots" content="index, follow" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site).href} />
    <meta property="og:site_name" content="Bhaumik's Notes" />
    <meta property="og:url" content={canonicalURL} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@bhaumikkaji" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site).href} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Bhaumik's Notes" href="/feed.xml" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Merriweather:wght@400;500;700&family=Lora:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&family=Geist:wght@400;500;600;700&family=Raleway:wght@100..900&family=JetBrains+Mono:wght@400;500&family=Chakra+Petch:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <script is:inline>
      // Prevent flash — apply mode before render
      (function() {
        const accentColors = {
          light: { accent: '#1a1a1a', accentHover: '#333333' },
          sepia: { accent: '#2E1F14', accentHover: '#1a1108' },
          dark:  { accent: '#e0e0e0', accentHover: '#f0f0f0' },
        };
        const mode = localStorage.getItem('mode') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-mode', mode);

        const c = accentColors[mode] || accentColors.light;
        const r = document.documentElement.style;
        r.setProperty('--accent', c.accent);
        r.setProperty('--accent-hover', c.accentHover);
        r.setProperty('--accent-gradient', c.accent);
        r.setProperty('--accent-gradient-from', c.accent);
        r.setProperty('--accent-gradient-to', c.accentHover);

        if (mode === 'dark') {
          r.setProperty('--bg', '#111111');
          r.setProperty('--bg-rgb', '17,17,17');
          r.setProperty('--text-primary', '#f0f0f0');
          r.setProperty('--text-primary-rgb', '240,240,240');
          r.setProperty('--text-secondary', '#a0a0a0');
          r.setProperty('--text-tertiary', '#666666');
          r.setProperty('--border', '#2a2a2a');
        } else if (mode === 'sepia') {
          r.setProperty('--bg', '#F2DCD0');
          r.setProperty('--bg-rgb', '242,220,208');
          r.setProperty('--text-primary', '#2E1F14');
          r.setProperty('--text-primary-rgb', '46,31,20');
          r.setProperty('--text-secondary', '#5E4A3B');
          r.setProperty('--text-tertiary', '#7D6959');
          r.setProperty('--border', '#D9C4B5');
        } else {
          r.setProperty('--bg', '#fafafa');
          r.setProperty('--bg-rgb', '250,250,250');
          r.setProperty('--text-primary', '#111111');
          r.setProperty('--text-primary-rgb', '17,17,17');
          r.setProperty('--text-secondary', '#555555');
          r.setProperty('--text-tertiary', '#777777');
          r.setProperty('--border', '#e8e8e8');
        }

        // Apply font
        var fonts = {
          'source-sans': "'Source Sans 3', 'Source Sans Pro', -apple-system, BlinkMacSystemFont, sans-serif",
          'merriweather': "'Merriweather', Georgia, serif",
          'lora': "'Lora', Georgia, serif",
          'ibm-plex': "'IBM Plex Sans', system-ui, sans-serif",
          'geist': "'Geist', 'Inter', system-ui, sans-serif",
          'chakra-petch': "'Chakra Petch', sans-serif",
        };
        var storedFont = localStorage.getItem('font') || 'source-sans';
        if (fonts[storedFont]) r.setProperty('--font-sans', fonts[storedFont]);

        // Apply font size
        var storedFontSize = localStorage.getItem('fontSize') || 'medium';
        var fontSizes = { small: { scale: '1' }, medium: { scale: '1.15' }, large: { scale: '1.3' }, xlarge: { scale: '1.45' } };
        var fs = fontSizes[storedFontSize];
        if (fs) r.setProperty('--font-size-scale', fs.scale);

        // Listen for system preference changes (only if user hasn't manually chosen a mode)
        var darkMQ = window.matchMedia('(prefers-color-scheme: dark)');
        function applySystemMode(dark) {
          // Only auto-switch if no manual preference stored
          if (!localStorage.getItem('mode')) {
            var sysMode = dark ? 'dark' : 'light';
            document.documentElement.setAttribute('data-mode', sysMode);
            var sc = accentColors[sysMode] || accentColors.light;
            r.setProperty('--accent', sc.accent);
            r.setProperty('--accent-hover', sc.accentHover);
            r.setProperty('--accent-gradient', sc.accent);
            r.setProperty('--accent-gradient-from', sc.accent);
            r.setProperty('--accent-gradient-to', sc.accentHover);
            if (sysMode === 'dark') {
              r.setProperty('--bg', '#111111'); r.setProperty('--bg-rgb', '17,17,17');
              r.setProperty('--text-primary', '#f0f0f0'); r.setProperty('--text-primary-rgb', '240,240,240');
              r.setProperty('--text-secondary', '#a0a0a0'); r.setProperty('--text-tertiary', '#666666');
              r.setProperty('--border', '#2a2a2a');
            } else {
              r.setProperty('--bg', '#fafafa'); r.setProperty('--bg-rgb', '250,250,250');
              r.setProperty('--text-primary', '#111111'); r.setProperty('--text-primary-rgb', '17,17,17');
              r.setProperty('--text-secondary', '#555555'); r.setProperty('--text-tertiary', '#777777');
              r.setProperty('--border', '#e8e8e8');
            }
          }
        }
        darkMQ.addEventListener('change', function(e) { applySystemMode(e.matches); });
      })();
    </script>
    <title>{title} ・ Bhaumik's Notes</title>

    <style is:global>
      :root {
        --bg: #fafafa;
        --bg-rgb: 250,250,250;
        --text-primary: #111111;
        --text-primary-rgb: 17,17,17;
        --text-secondary: #555555;
        --text-tertiary: #777777;
        --border: #e8e8e8;
        --accent: #1a1a1a;
        --accent-hover: #333333;
        --accent-gradient: #1a1a1a;
        --accent-gradient-from: #1a1a1a;
        --accent-gradient-to: #333333;
        --max-width: 1024px;
        --font-sans: 'Source Sans 3', 'Source Sans Pro', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        --font-mono: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
        --progress-height: 4px;
        --base-font-size: 11px;
        --base-line-height: 1.7;
        --para-spacing: 1em;
        --font-size-scale: 1;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-family: var(--font-sans);
        font-size: calc(var(--base-font-size) * var(--font-size-scale));
        line-height: var(--base-line-height);
        color: var(--text-primary);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        scroll-behavior: smooth;
        transition: background 0.3s ease, color 0.3s ease;
      }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* Page transitions */
      .content {
        animation: fadeUp 0.3s ease both;
      }

      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(6px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      a {
        color: var(--accent);
        text-decoration: none;
        transition: color 0.15s ease, opacity 0.15s ease;
      }

      a:hover {
        color: var(--accent-hover);
      }

      a:focus-visible,
      button:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
        border-radius: 2px;
      }

      /* Scroll progress bar */
      .scroll-progress {
        position: fixed;
        top: 0;
        left: 0;
        height: var(--progress-height);
        background: linear-gradient(90deg, #ff2d55, #ff9500, #ffcc00, #4cd964, #5ac8fa, #007aff, #af52de, #ff2d55);
        z-index: 9999;
        width: 0%;
        transition: width 0.05s linear;
        border-radius: 0 1px 1px 0;
      }

      /* Layout */
      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 20px;
      }

      /* Header */
      header {
        padding: 16px 0;
        position: sticky;
        top: 0;
        z-index: 100;
        background: color-mix(in srgb, var(--bg) 72%, transparent);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border-bottom: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
        transition: background 0.3s ease, border-color 0.3s ease;
      }

      .masthead {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .masthead-title {
        display: flex;
        align-items: center;
      }

      .masthead-title a {
        color: var(--accent);
        text-decoration: none;
        display: flex;
        align-items: center;
        font-family: 'Raleway', sans-serif;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.01em;
        gap: 0;
      }

      .masthead-title a .ml {
        transition: font-weight 0.2s ease, transform 0.2s ease, opacity 0.2s ease;
        display: inline-block;
      }

      .masthead-title a:hover {
        opacity: 1;
      }

      .masthead-right {
        display: flex;
        align-items: center;
        gap: 16px;
        font-size: 1.1rem;
      }

      .masthead-right a {
        color: var(--text-tertiary);
        text-decoration: none;
        transition: color 0.15s ease;
      }

      .masthead-right a:hover,
      .masthead-right a.nav-active {
        color: var(--accent);
      }

      /* Responsive header */
      @media (max-width: 640px) {
        .masthead-right {
          gap: 10px;
          font-size: 1rem;
        }

        header .container,
        footer .container {
          padding: 0 24px;
        }
      }

      /* Main content */
      .content {
        padding: 24px 0 24px;
        flex: 1;
      }

      /* Footer */
      footer {
        padding: 16px 0;
        border-top: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
        font-size: 1rem;
        color: var(--text-tertiary);
        position: sticky;
        bottom: 0;
        z-index: 100;
        background: color-mix(in srgb, var(--bg) 72%, transparent);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        transition: background 0.3s ease, border-color 0.3s ease;
      }

      footer .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      footer a {
        color: var(--text-tertiary);
        margin-left: 12px;
      }

      footer a:hover {
        color: var(--text-secondary);
      }

      /* Skip link */
      .skip-link {
        position: absolute;
        left: -9999px;
        top: auto;
        width: 1px;
        height: 1px;
        overflow: hidden;
        z-index: 99999;
        background: var(--accent);
        color: white;
        padding: 8px 16px;
        font-size: 14px;
      }

      .skip-link:focus {
        position: fixed;
        top: 8px;
        left: 8px;
        width: auto;
        height: auto;
        overflow: visible;
        border-radius: 4px;
      }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
      }

      /* Responsive */
      @media (max-width: 640px) {
        html {
          --base-font-size: 10px;
        }

        .container {
          padding: 0 24px;
        }
      }
    </style>
  </head>
  <body>
    <div class="scroll-progress" id="scroll-progress" style={showScrollProgress ? '' : 'display:none;'}></div>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <header role="banner">
      <div class="container">
        <nav role="navigation" aria-label="Main navigation">
          <div class="masthead">
            <h4 class="masthead-title">
              <a href="/" aria-label="Home"><span class="ml">B</span><span class="ml">h</span><span class="ml">a</span><span class="ml">u</span><span class="ml">m</span><span class="ml">i</span><span class="ml">k</span><span class="ml">'</span><span class="ml">s</span><span class="ml" style="margin: 0 4px"> </span><span class="ml">N</span><span class="ml">o</span><span class="ml">t</span><span class="ml">e</span><span class="ml">s</span></a>
            </h4>
            <div class="masthead-right">
              <a href="/notes" class={Astro.url.pathname === '/notes' || Astro.url.pathname === '/notes/' ? 'nav-active' : ''}>Index</a>
              <a href="/resources" class={Astro.url.pathname === '/resources' ? 'nav-active' : ''}>Resources</a>
              <Personalize />
            </div>
          </div>
        </nav>
      </div>
    </header>

    <main id="main-content" role="main" class="container content">
      <slot />
    </main>

    <footer>
      <div class="container">
        <span>&copy; {new Date().getFullYear()} Bhaumik Kaji</span>
        <span>
          <a href="https://twitter.com/bhaumikkaji">Twitter</a>
          <a href="https://linkedin.com/in/bhaumikkaji">LinkedIn</a>
          <a href="mailto:bhaumik@bhaumikkaji.com">Email</a>
          <a href="/feed.xml">RSS</a>
        </span>
      </div>
    </footer>

    <script is:inline>
      // Scroll progress
      const progressBar = document.getElementById('scroll-progress');
      function updateProgress() {
        if (!progressBar) return;
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        progressBar.style.width = progress + '%';
      }
      window.addEventListener('scroll', updateProgress, { passive: true });
      window.addEventListener('resize', updateProgress, { passive: true });
      updateProgress();

      // Masthead title — variable font weight wave on hover
      (function() {
        const link = document.querySelector('.masthead-title a');
        if (!link) return;
        const letters = link.querySelectorAll('.ml');
        if (!letters.length) return;

        const BASE_WEIGHT = 600;
        const PEAK_WEIGHT = 800;

        function applyWeightWave(x) {
          letters.forEach(function(el) {
            var rect = el.getBoundingClientRect();
            var letterCenter = rect.left + rect.width / 2;
            var distance = Math.abs(x - letterCenter);
            var maxDist = 120;
            var weight;
            var opacity;
            if (distance < maxDist) {
              var t = 1 - (distance / maxDist);
              // Ease: sharper peak at center
              var eased = t * t * (3 - 2 * t);
              weight = BASE_WEIGHT + (PEAK_WEIGHT - BASE_WEIGHT) * eased;
              // Opacity: peak is fully opaque (1), edges fade to 0.3
              opacity = 0.3 + 0.7 * eased;
            } else {
              weight = 200;
              opacity = 0.3;
            }
            el.style.fontWeight = Math.round(weight);
            el.style.opacity = opacity;
            // Subtle vertical lift for hovered letter
            var lift = distance < maxDist ? (1 - distance / maxDist) * 1 : 0;
            el.style.transform = lift > 0 ? 'translateY(-' + lift + 'px)' : '';
          });
        }

        function resetWeights() {
          letters.forEach(function(el) {
            el.style.fontWeight = BASE_WEIGHT;
            el.style.opacity = '';
            el.style.transform = '';
          });
        }

        link.addEventListener('mousemove', function(e) {
          applyWeightWave(e.clientX);
        });
        link.addEventListener('mouseleave', resetWeights);
      })();
    </script>
  </body>
</html>