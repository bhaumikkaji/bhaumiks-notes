---
import Personalize from '../components/Personalize.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  showScrollProgress?: boolean;
}

const { title, description = 'Notes on tech, design, and AI by Bhaumik Kaji.', image = '/images/og-default.svg', type = 'website', showScrollProgress = true } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" data-mode="light" data-theme="ember">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#fafafa" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />
    <meta name="author" content="Bhaumik Kaji" />
    <meta name="robots" content="index, follow" />

    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site).href} />
    <meta property="og:site_name" content="Bhaumik's Notes" />
    <meta property="og:url" content={canonicalURL} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@bhaumikkaji" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site).href} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Bhaumik's Notes" href="/feed.xml" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <script is:inline>
      // Prevent flash — apply theme + mode before render
      (function() {
        const theme = localStorage.getItem('theme') || 'ember';
        const mode = localStorage.getItem('mode') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.setAttribute('data-mode', mode);

        // Set accent CSS vars immediately
        const themes = {
          ember:    { light: { accent: '#c2410c', accentHover: '#a83608' }, dark: { accent: '#fb923c', accentHover: '#f97316' } },
          electric: { light: { accent: '#2563eb', accentHover: '#1d4ed8' }, dark: { accent: '#60a5fa', accentHover: '#3b82f6' } },
          violet:   { light: { accent: '#7c3aed', accentHover: '#6d28d9' }, dark: { accent: '#a78bfa', accentHover: '#8b5cf6' } },
          emerald:  { light: { accent: '#059669', accentHover: '#047857' }, dark: { accent: '#34d399', accentHover: '#10b981' } },
          rose:     { light: { accent: '#db2777', accentHover: '#be185d' }, dark: { accent: '#f472b6', accentHover: '#ec4899' } },
          sunset:   { light: { accent: '#f97316', accentHover: '#ea580c', gf: '#f97316', gt: '#ec4899' }, dark: { accent: '#fb923c', accentHover: '#f97316', gf: '#fb923c', gt: '#f472b6' } },
          aurora:   { light: { accent: '#06b6d4', accentHover: '#0891b2', gf: '#06b6d4', gt: '#8b5cf6' }, dark: { accent: '#22d3ee', accentHover: '#06b6d4', gf: '#22d3ee', gt: '#a78bfa' } },
          lava:     { light: { accent: '#ef4444', accentHover: '#dc2626', gf: '#ef4444', gt: '#f59e0b' }, dark: { accent: '#f87171', accentHover: '#ef4444', gf: '#f87171', gt: '#fbbf24' } },
        };
        const t = themes[theme] || themes.ember;
        const c = t[mode] || t.dark;
        const r = document.documentElement.style;
        r.setProperty('--accent', c.accent);
        r.setProperty('--accent-hover', c.accentHover);
        if (c.gf) {
          r.setProperty('--accent-gradient', 'linear-gradient(135deg,' + c.gf + ',' + c.gt + ')');
          r.setProperty('--accent-gradient-from', c.gf);
          r.setProperty('--accent-gradient-to', c.gt);
        } else {
          r.setProperty('--accent-gradient', c.accent);
          r.setProperty('--accent-gradient-from', c.accent);
          r.setProperty('--accent-gradient-to', c.accentHover);
        }

        // Set neutral palette
        if (mode === 'dark') {
          r.setProperty('--bg', '#111111');
          r.setProperty('--text-primary', '#f0f0f0');
          r.setProperty('--text-secondary', '#a0a0a0');
          r.setProperty('--text-tertiary', '#666666');
          r.setProperty('--border', '#2a2a2a');
        } else {
          r.setProperty('--bg', '#fafafa');
          r.setProperty('--text-primary', '#111111');
          r.setProperty('--text-secondary', '#555555');
          r.setProperty('--text-tertiary', '#888888');
          r.setProperty('--border', '#e8e8e8');
        }
      })();
    </script>
    <title>{title} ・ Bhaumik.sudo</title>

    <style is:global>
      :root {
        --bg: #fafafa;
        --text-primary: #111111;
        --text-secondary: #555555;
        --text-tertiary: #888888;
        --border: #e8e8e8;
        --accent: #c2410c;
        --accent-hover: #a83608;
        --accent-gradient: #c2410c;
        --accent-gradient-from: #c2410c;
        --accent-gradient-to: #a83608;
        --max-width: 640px;
        --font-sans: 'Source Sans 3', 'Source Sans Pro', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        --font-mono: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
        --progress-height: 2px;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-family: var(--font-sans);
        font-size: 11px;
        line-height: 1.7;
        color: var(--text-primary);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        scroll-behavior: smooth;
      }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      a {
        color: var(--accent);
        text-decoration: none;
        transition: color 0.15s ease;
      }

      a:hover {
        color: var(--accent-hover);
      }

      /* Scroll progress bar */
      .scroll-progress {
        position: fixed;
        top: 0;
        left: 0;
        height: var(--progress-height);
        background: linear-gradient(90deg, var(--accent), var(--accent-hover));
        z-index: 9999;
        width: 0%;
        transition: width 0.05s linear;
        border-radius: 0 1px 1px 0;
      }

      /* Layout */
      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 20px;
      }

      /* Header */
      header {
        padding: 16px 0;
        position: sticky;
        top: 0;
        z-index: 100;
        background: var(--bg);
        border-bottom: 1px solid var(--border);
      }

      .masthead {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .masthead-title {
        display: flex;
        align-items: center;
      }

      .masthead-title a {
        color: var(--accent);
        text-decoration: none;
        display: flex;
        align-items: center;
      }

      .masthead-title a:hover {
        opacity: 0.7;
      }

      .masthead-right {
        display: flex;
        align-items: center;
        gap: 16px;
        font-size: 1.1rem;
      }

      .masthead-right a {
        color: var(--text-tertiary);
        text-decoration: none;
        transition: color 0.15s ease;
      }

      .masthead-right a:hover,
      .masthead-right a.nav-active {
        color: var(--accent);
      }

      /* Responsive header */
      @media (max-width: 640px) {
        .masthead-right {
          gap: 10px;
          font-size: 1rem;
        }
      }

      /* Main content */
      .content {
        padding: 24px 0 24px;
        flex: 1;
      }

      /* Footer */
      footer {
        padding: 16px 0;
        border-top: 1px solid var(--border);
        font-size: 1rem;
        color: var(--text-tertiary);
        position: sticky;
        bottom: 0;
        z-index: 100;
        background: var(--bg);
      }

      footer .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      footer a {
        color: var(--text-tertiary);
        margin-left: 12px;
      }

      footer a:hover {
        color: var(--text-secondary);
      }

      /* Skip link */
      .skip-link {
        position: absolute;
        left: -9999px;
        top: auto;
        width: 1px;
        height: 1px;
        overflow: hidden;
        z-index: 99999;
        background: var(--accent);
        color: white;
        padding: 8px 16px;
        font-size: 14px;
      }

      .skip-link:focus {
        position: fixed;
        top: 8px;
        left: 8px;
        width: auto;
        height: auto;
        overflow: visible;
        border-radius: 4px;
      }

      /* Responsive */
      @media (max-width: 640px) {
        html {
          font-size: 10px;
        }
      }

      @media (min-width: 641px) {
        :root {
          --max-width: 640px;
        }
      }
    </style>
  </head>
  <body>
    <div class="scroll-progress" id="scroll-progress" style={showScrollProgress ? '' : 'display:none;'}></div>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <header role="banner">
      <div class="container">
        <nav role="navigation" aria-label="Main navigation">
          <div class="masthead">
            <h4 class="masthead-title">
              <a href="/" aria-label="Home">Bhaumik.sudo</a>
            </h4>
            <div class="masthead-right">
              <a href="/notes" class={Astro.url.pathname.startsWith('/notes') ? 'nav-active' : ''}>Notes</a>
              <a href="/resources" class={Astro.url.pathname === '/resources' ? 'nav-active' : ''}>Resources</a>
              <Personalize />
            </div>
          </div>
        </nav>
      </div>
    </header>

    <main id="main-content" role="main" class="container content">
      <slot />
    </main>

    <footer>
      <div class="container">
        <span>&copy; {new Date().getFullYear()} Bhaumik Kaji</span>
        <span>
          <a href="https://twitter.com/bhaumikkaji">Twitter</a>
          <a href="mailto:bhaumik@bhaumikkaji.com">Email</a>
          <a href="/feed.xml">RSS</a>
        </span>
      </div>
    </footer>

    <script is:inline>
      // Scroll progress
      const progressBar = document.getElementById('scroll-progress');
      function updateProgress() {
        if (!progressBar) return;
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        progressBar.style.width = progress + '%';
      }
      window.addEventListener('scroll', updateProgress, { passive: true });
      window.addEventListener('resize', updateProgress, { passive: true });
      updateProgress();
    </script>
  </body>
</html>