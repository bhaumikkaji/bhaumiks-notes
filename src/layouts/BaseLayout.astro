---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const { title, description = 'Notes on tech, design, and AI by Bhaumik Kaji.', image = '/images/og-default.svg', type = 'website' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#111111" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />
    <meta name="author" content="Bhaumik Kaji" />
    <meta name="robots" content="index, follow" />

    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site).href} />
    <meta property="og:site_name" content="Bhaumik's Notes" />
    <meta property="og:url" content={canonicalURL} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@bhaumikkaji" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site).href} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Bhaumik's Notes" href="/feed.xml" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <title>{title} ・ Bhaumik Kaji</title>

    <style is:global>
      :root {
        --bg: #fafafa;
        --text-primary: #111111;
        --text-secondary: #555555;
        --text-tertiary: #888888;
        --border: #e8e8e8;
        --accent: #c2410c;
        --accent-hover: #a83608;
        --tag-design: #7c3aed;
        --tag-ai: #d97706;
        --tag-tech: #2563eb;
        --tag-career: #059669;
        --tag-observations: #6b7280;
        --tag-life: #db2777;
        --max-width: 640px;
        --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        --font-mono: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
        --progress-height: 2px;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #111111;
          --text-primary: #f0f0f0;
          --text-secondary: #a0a0a0;
          --text-tertiary: #666666;
          --border: #2a2a2a;
          --accent: #fb923c;
          --accent-hover: #f97316;
          --tag-design: #a78bfa;
          --tag-ai: #fbbf24;
          --tag-tech: #60a5fa;
          --tag-career: #34d399;
          --tag-observations: #9ca3af;
          --tag-life: #f472b6;
        }
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-family: var(--font-sans);
        font-size: 16px;
        line-height: 1.7;
        color: var(--text-primary);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        scroll-behavior: smooth;
      }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      a {
        color: var(--accent);
        text-decoration: none;
        transition: color 0.15s ease;
      }

      a:hover {
        color: var(--accent-hover);
      }

      /* Scroll progress bar */
      .scroll-progress {
        position: fixed;
        top: 0;
        left: 0;
        height: var(--progress-height);
        background: linear-gradient(90deg, var(--accent), var(--accent-hover));
        z-index: 9999;
        width: 0%;
        transition: width 0.05s linear;
        border-radius: 0 1px 1px 0;
      }

      /* Layout */
      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 20px;
      }

      /* Header */
      header {
        padding: 48px 0 24px;
      }

      .masthead {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
      }

      .masthead-title {
        font-size: 14px;
        font-weight: 500;
        letter-spacing: -0.01em;
      }

      .masthead-title a {
        color: var(--text-primary);
        text-decoration: none;
      }

      .masthead-title a:hover {
        color: var(--text-secondary);
      }

      .masthead-title .text-grey {
        color: var(--text-tertiary);
      }

      .masthead-nav {
        display: flex;
        gap: 20px;
        font-size: 13px;
      }

      .masthead-nav a {
        color: var(--text-tertiary);
        text-decoration: none;
        transition: color 0.15s ease;
      }

      .masthead-nav a:hover,
      .masthead-nav a.nav-active {
        color: var(--text-primary);
      }

      /* Main content */
      .content {
        padding: 24px 0 64px;
        flex: 1;
      }

      /* Footer */
      footer {
        padding: 24px 0;
        border-top: 1px solid var(--border);
        font-size: 12px;
        color: var(--text-tertiary);
      }

      footer .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      footer a {
        color: var(--text-tertiary);
        margin-left: 12px;
      }

      footer a:hover {
        color: var(--text-secondary);
      }

      /* Skip link */
      .skip-link {
        position: absolute;
        left: -9999px;
        top: auto;
        width: 1px;
        height: 1px;
        overflow: hidden;
        z-index: 99999;
        background: var(--accent);
        color: white;
        padding: 8px 16px;
        font-size: 14px;
      }

      .skip-link:focus {
        position: fixed;
        top: 8px;
        left: 8px;
        width: auto;
        height: auto;
        overflow: visible;
        border-radius: 4px;
      }

      /* Responsive */
      @media (max-width: 640px) {
        .masthead {
          flex-direction: column;
          gap: 8px;
        }
        html {
          font-size: 15px;
        }
      }

      @media (min-width: 641px) {
        :root {
          --max-width: 640px;
        }
      }
    </style>
  </head>
  <body>
    <div class="scroll-progress" id="scroll-progress"></div>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <header role="banner">
      <div class="container">
        <nav role="navigation" aria-label="Main navigation">
          <div class="masthead">
            <h4 class="masthead-title">
              <a href="/" aria-label="Home">Bhaumik <span class="text-grey">Kaji</span></a>
            </h4>
            <span class="masthead-nav" role="list">
              <a href="/notes" aria-label="Read my notes" class={Astro.url.pathname.startsWith('/notes') ? 'nav-active' : ''}>Notes</a>
            </span>
          </div>
        </nav>
      </div>
    </header>

    <main id="main-content" role="main" class="container content">
      <slot />
    </main>

    <footer>
      <div class="container">
        <span>© {new Date().getFullYear()} Bhaumik Kaji</span>
        <span>
          <a href="https://twitter.com/bhaumikkaji">Twitter</a>
          <a href="mailto:bhaumik@bhaumikkaji.com">Email</a>
          <a href="/feed.xml">RSS</a>
        </span>
      </div>
    </footer>

    <script>
      const progressBar = document.getElementById('scroll-progress');
      function updateProgress() {
        if (!progressBar) return;
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        progressBar.style.width = progress + '%';
      }
      window.addEventListener('scroll', updateProgress, { passive: true });
      window.addEventListener('resize', updateProgress, { passive: true });
      updateProgress();
    </script>
  </body>
</html>