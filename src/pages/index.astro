---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes');
const notes = allNotes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const allTags = notes.flatMap(n => Array.isArray(n.data.category) ? n.data.category : [n.data.category]);
const tags = [...new Set(allTags)];
---

<BaseLayout title="Notes" description="Notes on tech, design, and AI by Bhaumik Kaji." showScrollProgress={true}>
  <div class="notes-page">
    <div class="notes-header">
      <h1>Notes</h1>
      <p>Notes on tech, design, and AI. By Bhaumik Kaji.</p>
    </div>

    <div class="notes-filter">
      <button class="filter-btn active" data-filter="all" aria-pressed="true">All</button>
      {tags.map((tag) => (
        <button class="filter-btn" data-filter={tag} aria-pressed="false">{tag}</button>
      ))}
    </div>

    <div class="notes-list">
      {notes.map((note) => {
        const primaryCat = Array.isArray(note.data.category) ? note.data.category[0] : note.data.category;
        const allCats = Array.isArray(note.data.category) ? note.data.category.join(',') : note.data.category;
        return (
          <a href={`/notes/${note.data.slug}`} class="note-entry" data-category={allCats}>
            <div class="note-main">
              <div class="note-top">
                <span class="note-list-title">{note.data.title}</span>
                <span class="note-list-date">{note.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              </div>
              <p class="note-list-desc">{note.data.summary || note.data.description}</p>
              <div class="note-list-tags">
                {Array.isArray(note.data.category) 
                  ? note.data.category.map(cat => <span class="note-tag">{cat}</span>)
                  : <span class="note-tag">{note.data.category}</span>
                }
              </div>
            </div>
            <span class="note-arrow">→</span>
          </a>
        );
      })}
    </div>
  </div>

  <script is:inline>
    const filterBtns = document.querySelectorAll('.notes-filter .filter-btn');
    const entries = document.querySelectorAll('.note-entry');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;
        filterBtns.forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
        entries.forEach(entry => {
          const cats = entry.dataset.category || '';
          entry.style.display = (filter === 'all' || cats.split(',').includes(filter)) ? '' : 'none';
        });
      });
    });
  </script>
</BaseLayout>

<style>
  .notes-page {
    padding-top: 40px;
    padding-bottom: 60px;
    width: 100%;
  }

  .notes-header {
    margin-bottom: 32px;
  }

  .notes-header h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 8px;
  }

  .notes-header p {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.5;
  }

  .notes-filter {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .filter-btn {
    padding: 4px 12px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: transparent;
    color: var(--text-tertiary);
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.15s ease;
    font-family: inherit;
  }

  .filter-btn:hover {
    border-color: var(--text-tertiary);
    color: var(--text-secondary);
  }

  .filter-btn.active {
    border-color: var(--accent);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .notes-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .note-entry {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 16px 0;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
    text-decoration: none;
    color: inherit;
    transition: color 0.15s ease;
  }

  .note-entry:last-child {
    border-bottom: none;
  }

  .note-entry:hover {
    color: var(--accent);
  }

  .note-entry:hover .note-list-title {
    color: var(--accent);
  }

  .note-main {
    flex: 1;
    min-width: 0;
  }

  .note-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 4px;
  }

  .note-list-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
    transition: color 0.15s ease;
  }

  .note-list-date {
    font-size: 0.78rem;
    color: var(--text-tertiary);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .note-list-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.45;
    margin: 0 0 6px 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .note-list-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .note-tag {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 8px;
    border-radius: 10px;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .note-arrow {
    color: var(--text-tertiary);
    font-size: 0.9rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .note-entry:hover .note-arrow {
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .notes-header h1 {
      font-size: 1.6rem;
    }

    .notes-page {
      padding: 24px 0;
    }

    .note-top {
      flex-direction: column;
      gap: 2px;
    }

    .note-list-date {
      font-size: 0.72rem;
    }
  }
</style>
