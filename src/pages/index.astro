---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import Icon from '../components/Icon.astro';

const categoryIcons: Record<string, string> = {
  Design: 'pencil-ruler',
  AI: 'sparkles',
  Tech: 'code-2',
  Career: 'trending-up',
  Observations: 'eye',
  Life: 'heart',
};

const allNotes = await getCollection('notes');
const notes = allNotes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = notes.slice(0, 3);
const hero = featured[0];
const side = featured.slice(1);
---

<BaseLayout title="Bhaumik Kaji ・ Design & product thinker" description="Senior Product Designer at Microsoft. Sharing notes on tech, design and AI." showScrollProgress={false}>
  <div class="home" data-density="default">

    <!-- Bento Grid -->
    <div class="bento">
      <!-- Hero card -->
      <a href={`/notes/${hero.data.slug}`} class="bento-card bento-hero">
        <span class="card-category"><Icon name={categoryIcons[hero.data.category] || 'circle'} size={6} class="card-pill-icon" />{hero.data.category}</span>
        <h2 class="card-title">{hero.data.title}</h2>
        <p class="card-desc card-desc-default">{hero.data.summary || hero.data.description}</p>
        <p class="card-desc card-desc-compact">{hero.data.summaryCompact || hero.data.summary || hero.data.description}</p>
        <p class="card-desc card-desc-expanded">{hero.data.summaryExpanded || hero.data.summary || hero.data.description}</p>
        <span class="card-cta">Read →</span>
      </a>

      <!-- Side cards -->
      {side.map((note) => (
        <a href={`/notes/${note.data.slug}`} class="bento-card bento-side">
          <span class="card-category"><Icon name={categoryIcons[note.data.category] || 'circle'} size={6} class="card-pill-icon" />{note.data.category}</span>
          <h3 class="card-title">{note.data.title}</h3>
          <p class="card-desc card-desc-default">{note.data.summary || note.data.description}</p>
          <p class="card-desc card-desc-compact">{note.data.summaryCompact || note.data.summary || note.data.description}</p>
          <p class="card-desc card-desc-expanded">{note.data.summaryExpanded || note.data.summary || note.data.description}</p>
          <span class="card-cta">Read →</span>
        </a>
      ))}

    </div>

  </div>

  <script is:inline>
    const densityToggle = document.getElementById('density-toggle');
    const home = document.querySelector('.home');
    const stored = localStorage.getItem('density') || 'default';
    home.setAttribute('data-density', stored);
    densityToggle.querySelectorAll('.density-btn').forEach(btn => {
      btn.classList.toggle('density-active', btn.dataset.density === stored);
    });
    densityToggle.querySelectorAll('.density-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const density = btn.dataset.density;
        home.setAttribute('data-density', density);
        localStorage.setItem('density', density);
        densityToggle.querySelectorAll('.density-btn').forEach(b => b.classList.remove('density-active'));
        btn.classList.add('density-active');
      });
    });
  </script>
</BaseLayout>

<style>
  .home {
    padding-top: 24px;
    height: calc(100vh - 80px);
    display: flex;
    align-items: stretch;
  }

  /* ===== BENTO GRID — Default (4-col) ===== */
  .bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: 1fr 1fr;
    gap: 12px;
    width: 100%;
    height: 100%;
    transition: grid-template-columns 0.3s ease;
  }

  .bento-hero {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }

  .bento-side {
    grid-column: span 2;
  }

  .bento-card {
    background: color-mix(in srgb, var(--text-primary) 4%, transparent);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, background 0.2s ease;
    position: relative;
    overflow: hidden;
    min-height: 0;
  }

  .bento-card:hover {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
    background: color-mix(in srgb, var(--text-primary) 6%, transparent);
  }

  /* Category pill */
  .card-category {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px 3px 7px;
    border-radius: 12px;
    margin-bottom: 12px;
    align-self: flex-start;
    flex-shrink: 0;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .card-pill-icon {
    opacity: 0.85;
  }

  .card-pill-icon :global(svg) {
    display: block;
  }

  .card-title {
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 6px;
    flex-shrink: 0;
  }

  .bento-hero .card-title {
    font-size: 1.3rem;
  }

  .bento-side .card-title {
    font-size: 1rem;
  }

  /* Description — same font size across all densities, only content changes */
  .card-desc {
    color: var(--text-secondary);
    line-height: 1.5;
    flex: 1;
    min-height: 0;
    overflow: hidden;
    font-size: 0.95rem;
  }

  .card-desc-default {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-desc-compact {
    display: none;
  }

  .card-desc-expanded {
    display: none;
  }

  .card-cta {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--accent);
    margin-top: auto;
    flex-shrink: 0;
    padding-top: 8px;
  }

  /* About & Contact cards */
  /* ===== DENSITY: COMPACT (2-col) ===== */
  .home[data-density="compact"] .bento {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }

  .home[data-density="compact"] .bento-hero {
    grid-column: 1 / -1;
    grid-row: auto;
  }

  .home[data-density="compact"] .bento-side {
    grid-column: span 1;
  }

  .home[data-density="compact"] .card-desc-default { display: none !important; }
  .home[data-density="compact"] .card-desc-compact {
    display: -webkit-box !important;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .home[data-density="compact"] .card-desc-expanded { display: none !important; }

  /* ===== DENSITY: EXPANDED (4-col) ===== */
  .home[data-density="expanded"] .bento {
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: 1fr 1fr;
  }

  .home[data-density="expanded"] .card-desc-default { display: none !important; }
  .home[data-density="expanded"] .card-desc-compact { display: none !important; }
  .home[data-density="expanded"] .card-desc-expanded {
    display: block !important;
  }

  /* ===== Density buttons (in header) ===== */
  .density-btn {
    width: 30px;
    height: 30px;
    border: none;
    border-radius: 999px;
    background: transparent;
    color: var(--text-tertiary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .density-btn:hover {
    background: color-mix(in srgb, var(--text-primary) 6%, transparent);
    color: var(--text-secondary);
  }

  .density-btn.density-active {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
  }

  .density-btn :global(svg) {
    display: block;
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .home {
      height: auto;
      min-height: auto;
    }

    .bento {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
      height: auto;
    }

    .bento-hero {
      grid-column: 1 / -1;
      grid-row: auto;
    }

    .bento-side {
      grid-column: span 1;
    }

    .bento-hero .card-title {
      font-size: 1.3rem;
    }

    .bento-card {
      padding: 20px 16px;
    }

    .home[data-density="compact"] .bento,
    .home[data-density="default"] .bento,
    .home[data-density="expanded"] .bento {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
      gap: 10px;
    }
  }

  @media (max-width: 480px) {
    .bento {
      grid-template-columns: 1fr;
    }

    .bento-hero,
    .bento-side {
      grid-column: 1 / -1;
    }

    .bento-hero .card-title {
      font-size: 1.2rem;
    }
  }
</style>