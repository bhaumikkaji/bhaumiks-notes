---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes');
const notes = allNotes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 5);
---

<BaseLayout title="Bhaumik's Notes" description="Notes on tech, design, and AI. By Bhaumik Kaji." showScrollProgress={false}>
  <div class="home">
    <div class="notes-grid">
      {notes.map((note, i) => {
        const isHero = i === 0;
        return (
          <a href={`/notes/${note.data.slug}`} class={`note-card ${isHero ? 'card-hero' : ''}`} style={`animation-delay: ${i * 0.05}s`}>
            <h2 class="card-title">{note.data.title}</h2>
            <p class="card-desc">{note.data.summary || note.data.description}</p>
            <div class="card-meta">
              <span class="card-category">{Array.isArray(note.data.category) ? note.data.category[0] : note.data.category}</span>
              <span class="card-date">{note.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            </div>
          </a>
        );
      })}
    </div>

    <div class="home-about">
      <img src="/images/golden-key.png" alt="" class="about-key" />
      <p class="about-tagline">Notes on tech, design, and AI.</p>
      <p class="about-body">These are my notes — like a semi-frequently updated journal. Everything I write is born out of empirical learnings and everyday observations. There's obviously bias in these notes, but since honest personal accounts from people in tech are rare, I hope this serves as a useful one.</p>
      <div class="about-meta">
        <span class="meta-item">Senior Product Designer at <strong>Microsoft</strong></span>
        <span class="meta-divider">·</span>
        <span class="meta-item">Based in <strong>Toronto, Canada</strong></span>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .home {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: auto;
    padding: 16px 20px;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .notes-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    width: 100%;
    max-width: 1024px;
  }

  .note-card {
    animation: fadeUp 0.3s ease both;
    background: transparent;
    border: 1px solid var(--text-primary);
    border-radius: 14px;
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    position: relative;
    overflow: hidden;
    min-height: 160px;
  }

  .note-card.card-hero {
    grid-column: span 2;
    min-height: 200px;
  }

  .note-card.card-hero .card-title {
    font-size: 1.5rem;
  }

  .note-card:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--text-primary) 4%, transparent);
    box-shadow: 0 2px 12px color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .card-title {
    font-size: 1.18rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
    margin-bottom: 8px;
    flex-shrink: 0;
  }

  .card-desc {
    color: var(--text-secondary);
    line-height: 1.5;
    font-size: 0.95rem;
    flex: 1;
    min-height: 0;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    margin-bottom: 12px;
  }

  .card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
  }

  .card-category {
    display: inline-flex;
    align-items: center;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 10px;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .card-date {
    font-size: 0.78rem;
    color: var(--text-tertiary);
  }

  .home-about {
    max-width: 520px;
    text-align: center;
    margin: 20px auto 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .about-key {
    width: 64px;
    height: 64px;
    image-rendering: pixelated;
    margin-bottom: 4px;
    animation: fadeUp 0.3s ease both;
    animation-delay: 0.3s;
  }

  .about-tagline {
    font-size: 1rem;
    color: var(--text-secondary);
    margin-bottom: 4px;
    font-weight: 400;
    animation: fadeUp 0.3s ease both;
    animation-delay: 0.35s;
  }

  .about-body {
    color: var(--text-tertiary);
    font-size: 0.82rem;
    line-height: 1.5;
    margin-bottom: 8px;
    animation: fadeUp 0.3s ease both;
    animation-delay: 0.4s;
  }

  .about-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    flex-wrap: wrap;
    font-size: 0.82rem;
    color: var(--text-tertiary);
    animation: fadeUp 0.3s ease both;
    animation-delay: 0.45s;
  }

  .about-meta strong {
    color: var(--text-primary);
    font-weight: 500;
  }

  .meta-divider {
    color: var(--border);
  }

  @media (max-width: 640px) {
    .notes-grid {
      grid-template-columns: 1fr;
    }

    .note-card,
    .note-card.card-hero {
      grid-column: span 1;
      min-height: auto;
      padding: 20px 16px;
    }

    .card-title {
      font-size: 1.05rem;
    }
  }
</style>