---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import Icon from '../components/Icon.astro';

const categoryIcons: Record<string, string> = {
  Design: 'pencil-ruler',
  AI: 'sparkles',
  Tech: 'code-2',
  Career: 'trending-up',
  Observations: 'eye',
  Life: 'heart',
};

const allNotes = await getCollection('notes');
const notes = allNotes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = notes.slice(0, 3);
const hero = featured[0];
const side = featured.slice(1);
---

<BaseLayout title="Bhaumik Kaji ・ Design & product thinker" description="Senior Product Designer at Microsoft. Sharing notes on tech, design and AI.">
  <div class="home" data-density="default">

    <!-- Bento Grid -->
    <div class="bento">
      <!-- Hero card -->
      <a href={`/notes/${hero.data.slug}`} class="bento-card bento-hero">
        <span class="card-category"><Icon name={categoryIcons[hero.data.category] || 'circle'} size={12} class="card-pill-icon" />{hero.data.category}</span>
        <h2 class="card-title">{hero.data.title}</h2>
        <p class="card-desc card-desc-default">{hero.data.summary || hero.data.description}</p>
        <p class="card-desc card-desc-compact">{hero.data.summaryCompact || hero.data.summary || hero.data.description}</p>
        <p class="card-desc card-desc-expanded">{hero.data.summaryExpanded || hero.data.summary || hero.data.description}</p>
        <span class="card-cta">Read →</span>
      </a>

      <!-- Side cards -->
      {side.map((note) => (
        <a href={`/notes/${note.data.slug}`} class="bento-card bento-side">
          <span class="card-category"><Icon name={categoryIcons[note.data.category] || 'circle'} size={12} class="card-pill-icon" />{note.data.category}</span>
          <h3 class="card-title">{note.data.title}</h3>
          <p class="card-desc card-desc-default">{note.data.summary || note.data.description}</p>
          <p class="card-desc card-desc-compact">{note.data.summaryCompact || note.data.summary || note.data.description}</p>
          <p class="card-desc card-desc-expanded">{note.data.summaryExpanded || note.data.summary || note.data.description}</p>
          <span class="card-cta">Read →</span>
        </a>
      ))}

      <!-- About card -->
      <div class="bento-card bento-about">
        <span class="card-label">About</span>
        <p>Senior Product Designer at <strong>Microsoft</strong> — Copilot, Teams, Office Mobile. I write about product, design, and AI from empirical learnings.</p>
      </div>

      <!-- Contact card -->
      <div class="bento-card bento-contact">
        <span class="card-label">Get in touch</span>
        <div class="contact-links">
          <a href="https://twitter.com/bhaumikkaji">Twitter</a>
          <a href="mailto:bhaumik@bhaumikkaji.com">Email</a>
        </div>
      </div>
    </div>

  </div>

  <!-- Density toggle -->
  <div class="density-toggle" id="density-toggle">
    <button class="density-btn" data-density="compact" aria-label="Compact view">
      <Icon name="layout-list" size={14} />
    </button>
    <button class="density-btn density-active" data-density="default" aria-label="Default view">
      <Icon name="layout-grid" size={14} />
    </button>
    <button class="density-btn" data-density="expanded" aria-label="Expanded view">
      <Icon name="layout-dashboard" size={14} />
    </button>
  </div>

  <script is:inline>
    const densityToggle = document.getElementById('density-toggle');
    const home = document.querySelector('.home');
    const stored = localStorage.getItem('density') || 'default';
    home.setAttribute('data-density', stored);

    // Set active button
    densityToggle.querySelectorAll('.density-btn').forEach(btn => {
      btn.classList.toggle('density-active', btn.dataset.density === stored);
    });

    densityToggle.querySelectorAll('.density-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const density = btn.dataset.density;
        home.setAttribute('data-density', density);
        localStorage.setItem('density', density);
        densityToggle.querySelectorAll('.density-btn').forEach(b => b.classList.remove('density-active'));
        btn.classList.add('density-active');
      });
    });
  </script>
</BaseLayout>

<style>
  .home {
    padding-top: 40px;
    transition: all 0.3s ease;
  }

  /* ===== BENTO GRID — Default (4-col) ===== */
  .bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: auto auto;
    gap: 12px;
    transition: grid-template-columns 0.3s ease, gap 0.3s ease;
  }

  .bento-hero {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }

  .bento-side {
    grid-column: span 2;
  }

  .bento-about {
    grid-column: span 3;
  }

  .bento-contact {
    grid-column: span 1;
  }

  .bento-card {
    background: color-mix(in srgb, var(--text-primary) 4%, transparent);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, background 0.2s ease, padding 0.3s ease, border-radius 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .bento-card:hover {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
    background: color-mix(in srgb, var(--text-primary) 6%, transparent);
  }

  /* Category pill */
  .card-category {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px 3px 7px;
    border-radius: 12px;
    margin-bottom: 16px;
    align-self: flex-start;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .card-pill-icon {
    opacity: 0.85;
  }

  .card-pill-icon :global(svg) {
    display: block;
  }

  .card-title {
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
    margin-bottom: 8px;
    transition: font-size 0.3s ease;
  }

  .bento-hero .card-title {
    font-size: 1.72rem;
  }

  .bento-side .card-title {
    font-size: 1.27rem;
  }

  /* Description visibility by density */
  .card-desc {
    color: var(--text-secondary);
    line-height: 1.55;
    margin-bottom: 16px;
    flex: 1;
    transition: opacity 0.2s ease, max-height 0.3s ease, font-size 0.3s ease;
  }

  .card-desc-default { font-size: 1.09rem; }
  .card-desc-compact { display: none; }
  .card-desc-expanded { display: none; }

  .card-cta {
    font-size: 1rem;
    font-weight: 500;
    color: var(--accent);
    margin-top: auto;
  }

  /* About & Contact cards */
  .card-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: 12px;
  }

  .bento-about p {
    font-size: 1.09rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .bento-about p strong {
    color: var(--text-primary);
  }

  .bento-contact {
    justify-content: center;
    text-align: center;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .contact-links a {
    color: var(--accent);
    font-size: 1rem;
    font-weight: 500;
  }

  /* ===== DENSITY: COMPACT (2-col, tight) ===== */
  .home[data-density="compact"] .bento {
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .home[data-density="compact"] .bento-hero {
    grid-column: 1 / -1;
    grid-row: auto;
    padding: 20px 18px;
  }

  .home[data-density="compact"] .bento-side {
    grid-column: span 1;
    padding: 18px 14px;
  }

  .home[data-density="compact"] .bento-about {
    grid-column: 1 / -1;
    padding: 18px 14px;
  }

  .home[data-density="compact"] .bento-contact {
    grid-column: 1 / -1;
    padding: 18px 14px;
  }

  .home[data-density="compact"] .bento-hero .card-title {
    font-size: 1.36rem;
  }

  .home[data-density="compact"] .bento-side .card-title {
    font-size: 1rem;
  }

  .home[data-density="compact"] .card-desc-default { display: none; }
  .home[data-density="compact"] .card-desc-compact { display: block; font-size: 0.95rem; }
  .home[data-density="compact"] .card-desc-expanded { display: none; }

  .home[data-density="compact"] .bento-side .card-desc-compact {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ===== DENSITY: EXPANDED (4-col, generous) ===== */
  .home[data-density="expanded"] .bento {
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .home[data-density="expanded"] .bento-card {
    padding: 36px 28px;
    border-radius: 20px;
  }

  .home[data-density="expanded"] .bento-hero .card-title {
    font-size: 2rem;
  }

  .home[data-density="expanded"] .bento-side .card-title {
    font-size: 1.45rem;
  }

  .home[data-density="expanded"] .card-desc-default { display: none; }
  .home[data-density="expanded"] .card-desc-compact { display: none; }
  .home[data-density="expanded"] .card-desc-expanded { display: block; font-size: 1.18rem; line-height: 1.65; }

  .home[data-density="expanded"] .bento-about p {
    font-size: 1.18rem;
    line-height: 1.7;
  }

  /* ===== DENSITY TOGGLE ===== */
  .density-toggle {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 1000;
    display: flex;
    gap: 4px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 4px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  .density-btn {
    width: 36px;
    height: 36px;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: var(--text-tertiary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .density-btn:hover {
    background: color-mix(in srgb, var(--text-primary) 6%, transparent);
    color: var(--text-secondary);
  }

  .density-btn.density-active {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
  }

  .density-btn :global(svg) {
    display: block;
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .bento {
      grid-template-columns: 1fr 1fr;
    }
    .bento-hero {
      grid-column: 1 / -1;
      grid-row: auto;
    }
    .bento-side {
      grid-column: span 1;
    }
    .bento-about {
      grid-column: 1 / -1;
    }
    .bento-contact {
      grid-column: 1 / -1;
    }
    /* Override density for mobile */
    .home[data-density="compact"] .bento,
    .home[data-density="default"] .bento,
    .home[data-density="expanded"] .bento {
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }
    .home[data-density="expanded"] .bento-card {
      padding: 24px 18px;
      border-radius: 16px;
    }
    .home[data-density="expanded"] .bento-hero .card-title {
      font-size: 1.72rem;
    }
    .bento-hero .card-title {
      font-size: 1.72rem;
    }
  }

  @media (max-width: 480px) {
    .bento {
      grid-template-columns: 1fr;
    }
    .bento-hero,
    .bento-side,
    .bento-about,
    .bento-contact {
      grid-column: 1 / -1;
    }
    .bento-hero .card-title {
      font-size: 1.45rem;
    }
    .density-toggle {
      bottom: 16px;
      right: 16px;
    }
  }
</style>