---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import CategoryPill from '../components/CategoryPill.astro';

const allNotes = await getCollection('notes');
const notes = allNotes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = notes.slice(0, 3);
const hero = featured[0];
const side = featured.slice(1);
---

<BaseLayout title="Bhaumik Kaji ・ Design & product thinker" description="Senior Product Designer at Microsoft. Sharing notes on tech, design and AI.">
  <div class="home">

    <!-- Bento Grid -->
    <div class="bento">

      <!-- Hero card — largest -->
      <a href={`/notes/${hero.data.slug}`} class="bento-card bento-hero">
        <span class="card-category" data-category={hero.data.category}>{hero.data.category}</span>
        <h2 class="card-title">{hero.data.title}</h2>
        <p class="card-desc">{hero.data.description}</p>
        <span class="card-cta">Read →</span>
      </a>

      <!-- Side cards -->
      {side.map((note) => (
        <a href={`/notes/${note.data.slug}`} class="bento-card bento-side">
          <span class="card-category" data-category={note.data.category}>{note.data.category}</span>
          <h3 class="card-title">{note.data.title}</h3>
          <span class="card-cta">Read →</span>
        </a>
      ))}

      <!-- About card -->
      <div class="bento-card bento-about">
        <span class="card-label">About</span>
        <p>Senior Product Designer at <strong>Microsoft</strong> — Copilot, Teams, Office Mobile. I write about product, design, and AI from empirical learnings.</p>
      </div>

      <!-- Contact card -->
      <div class="bento-card bento-contact">
        <span class="card-label">Get in touch</span>
        <div class="contact-links">
          <a href="https://twitter.com/bhaumikkaji">Twitter</a>
          <a href="mailto:bhaumik@bhaumikkaji.com">Email</a>
        </div>
      </div>

    </div>

    <!-- Full notes list below the bento -->
    <div class="notes-list-section">
      <h2 class="section-label">All notes</h2>
      <div class="notes-list">
        {notes.map((note) => (
          <div class="note-entry">
            <a href={`/notes/${note.data.slug}`} class="note-title">{note.data.title}</a>
            <CategoryPill category={note.data.category} />
          </div>
        ))}
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  .home {
    padding-top: 40px;
  }

  /* ===== BENTO GRID ===== */
  .bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: auto auto;
    gap: 12px;
    margin-bottom: 64px;
  }

  .bento-hero {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }

  .bento-side {
    grid-column: span 2;
  }

  .bento-about {
    grid-column: span 3;
  }

  .bento-contact {
    grid-column: span 1;
  }

  .bento-card {
    background: color-mix(in srgb, var(--text-primary) 4%, transparent);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, background 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .bento-card:hover {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
    background: color-mix(in srgb, var(--text-primary) 6%, transparent);
  }

  /* Card internals */
  .card-category {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 12px;
    margin-bottom: 16px;
    align-self: flex-start;
  }

  .card-category[data-category="Design"] {
    color: var(--tag-design);
    background: color-mix(in srgb, var(--tag-design) 12%, transparent);
  }
  .card-category[data-category="AI"] {
    color: var(--tag-ai);
    background: color-mix(in srgb, var(--tag-ai) 12%, transparent);
  }
  .card-category[data-category="Tech"] {
    color: var(--tag-tech);
    background: color-mix(in srgb, var(--tag-tech) 12%, transparent);
  }
  .card-category[data-category="Career"] {
    color: var(--tag-career);
    background: color-mix(in srgb, var(--tag-career) 12%, transparent);
  }
  .card-category[data-category="Observations"] {
    color: var(--tag-observations);
    background: color-mix(in srgb, var(--tag-observations) 12%, transparent);
  }
  .card-category[data-category="Life"] {
    color: var(--tag-life);
    background: color-mix(in srgb, var(--tag-life) 12%, transparent);
  }

  .card-title {
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
    margin-bottom: 8px;
  }

  .bento-hero .card-title {
    font-size: 1.72rem;
  }

  .bento-side .card-title {
    font-size: 1.27rem;
  }

  .card-desc {
    color: var(--text-secondary);
    font-size: 1.09rem;
    line-height: 1.55;
    margin-bottom: 16px;
    flex: 1;
  }

  .card-cta {
    font-size: 1rem;
    font-weight: 500;
    color: var(--accent);
    margin-top: auto;
  }

  /* About & Contact cards */
  .card-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: 12px;
  }

  .bento-about p {
    font-size: 1.09rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .bento-about p strong {
    color: var(--text-primary);
  }

  .bento-contact {
    justify-content: center;
    text-align: center;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .contact-links a {
    color: var(--accent);
    font-size: 1rem;
    font-weight: 500;
  }

  /* ===== Notes list ===== */
  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: 20px;
  }

  .notes-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .note-entry {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
    line-height: 1.5;
  }

  .note-title {
    font-size: 1.18rem;
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .note-title:hover {
    color: var(--accent);
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .bento {
      grid-template-columns: 1fr 1fr;
    }
    .bento-hero {
      grid-column: 1 / -1;
      grid-row: auto;
    }
    .bento-side {
      grid-column: span 1;
    }
    .bento-about {
      grid-column: 1 / -1;
    }
    .bento-contact {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .bento {
      grid-template-columns: 1fr;
    }
    .bento-hero,
    .bento-side,
    .bento-about,
    .bento-contact {
      grid-column: 1 / -1;
    }
    .bento-hero .card-title {
      font-size: 1.45rem;
    }
  }
</style>