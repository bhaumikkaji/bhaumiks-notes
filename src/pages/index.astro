---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import Icon from '../components/Icon.astro';

const categoryIcons: Record<string, string> = {
  Design: 'pencil-ruler',
  AI: 'sparkles',
  Tech: 'code-2',
  Career: 'trending-up',
  Observations: 'eye',
  Life: 'heart',
};

const allNotes = await getCollection('notes');
const notes = allNotes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = notes.slice(0, 6);
const hero = featured[0];
const side = featured.slice(1);
---

<BaseLayout title="Bhaumik Kaji ・ Design & product thinker" description="Senior Product Designer at Microsoft. Sharing notes on tech, design and AI." showScrollProgress={false}>
  <div class="home">
    <div class="bento">
      <!-- Hero card -->
      <a href={`/notes/${hero.data.slug}`} class="bento-card bento-hero">
        <span class="card-category"><Icon name={categoryIcons[hero.data.category] || 'circle'} size={6} class="card-pill-icon" />{hero.data.category}</span>
        <h2 class="card-title">{hero.data.title}</h2>
        <p class="card-desc">{hero.data.summary || hero.data.description}</p>
        <span class="card-cta">Read →</span>
      </a>

      <!-- Side cards -->
      {side.map((note) => (
        <a href={`/notes/${note.data.slug}`} class="bento-card bento-side">
          <span class="card-category"><Icon name={categoryIcons[note.data.category] || 'circle'} size={6} class="card-pill-icon" />{note.data.category}</span>
          <h3 class="card-title">{note.data.title}</h3>
          <p class="card-desc">{note.data.summary || note.data.description}</p>
          <span class="card-cta">Read →</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .home {
    padding-top: 24px;
    height: calc(100vh - 120px);
    display: flex;
    align-items: stretch;
  }

  .bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: 1fr 1fr 1fr;
    gap: 12px;
    width: 100%;
    height: 100%;
  }

  .bento-hero {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }

  .bento-side {
    grid-column: span 2;
  }

  .bento-card {
    background: color-mix(in srgb, var(--text-primary) 4%, transparent);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 18px 16px;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, background 0.2s ease;
    position: relative;
    overflow: hidden;
    min-height: 0;
  }

  .bento-card:hover {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
    background: color-mix(in srgb, var(--text-primary) 6%, transparent);
  }

  .card-category {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px 3px 7px;
    border-radius: 12px;
    margin-bottom: 12px;
    align-self: flex-start;
    flex-shrink: 0;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .card-pill-icon {
    opacity: 0.85;
  }

  .card-pill-icon :global(svg) {
    display: block;
  }

  .card-title {
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 6px;
    flex-shrink: 0;
  }

  .bento-hero .card-title {
    font-size: 1.15rem;
  }

  .bento-side .card-title {
    font-size: 0.95rem;
  }

  .card-desc {
    color: var(--text-secondary);
    line-height: 1.5;
    flex: 1;
    min-height: 0;
    overflow: hidden;
    font-size: 0.85rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .card-cta {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--accent);
    margin-top: auto;
    flex-shrink: 0;
    padding-top: 8px;
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .home {
      height: auto;
      min-height: auto;
    }

    .bento {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
      height: auto;
    }

    .bento-hero {
      grid-column: 1 / -1;
      grid-row: auto;
    }

    .bento-side {
      grid-column: span 1;
    }

    .bento-hero .card-title {
      font-size: 1.3rem;
    }

    .bento-card {
      padding: 20px 16px;
    }
  }

  @media (max-width: 480px) {
    .bento {
      grid-template-columns: 1fr;
    }

    .bento-hero,
    .bento-side {
      grid-column: 1 / -1;
    }

    .bento-hero .card-title {
      font-size: 1.2rem;
    }
  }
</style>