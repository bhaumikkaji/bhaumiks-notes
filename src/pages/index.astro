---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import CategoryPill from '../components/CategoryPill.astro';

const allNotes = await getCollection('notes');
const notes = allNotes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestNotes = notes.slice(0, 5);
---

<BaseLayout title="Bhaumik Kaji ・ Design & product thinker" description="Senior Product Designer at Microsoft. Sharing notes on tech, design and AI.">
  <div class="home">
    <div class="home-hero">
      <h1>I'm an AI & software design leader at <strong>Microsoft</strong>.</h1>
      <p class="hero-sub">Via Copilot, Teams, Office Mobile & more.</p>
      <p class="hero-body">Throughout my career, I've helped startups and large companies build and grow their products with great design. I've worked across AI, productivity, enterprise SaaS, and consumer domains.</p>
    </div>

    <div class="home-section">
      <h2 class="section-label">Latest notes</h2>
      <p class="section-desc">Notes on product, design and AI, born out of empirical learnings and everyday observations.</p>
      <div class="notes-preview">
        {latestNotes.map((note) => (
          <div class="note-entry">
            <a href={`/notes/${note.data.slug}`} class="note-title">{note.data.title}</a>
            <CategoryPill category={note.data.category} />
          </div>
        ))}
      </div>
      <a href="/notes" class="view-all">View all notes →</a>
    </div>

    <div class="home-section">
      <h2 class="section-label">Get in touch</h2>
      <p class="section-desc">I love conversations about design craft, product thinking, and building things that matter. Say hello anytime.</p>
      <div class="contact-links">
        <a href="https://twitter.com/bhaumikkaji">Twitter</a>
        <span class="dot">·</span>
        <a href="mailto:bhaumik@bhaumikkaji.com">Email</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .home {
    padding-top: 56px;
  }

  .home-hero {
    margin-bottom: 80px;
  }

  .home-hero h1 {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .hero-sub {
    font-size: 1.36rem;
    color: var(--text-secondary);
    margin-bottom: 8px;
  }

  .hero-body {
    font-size: 1.18rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .home-section {
    margin-bottom: 64px;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: 12px;
  }

  .section-desc {
    color: var(--text-secondary);
    margin-bottom: 24px;
    font-size: 1.18rem;
    line-height: 1.6;
  }

  .notes-preview {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 24px;
  }

  .note-entry {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
    line-height: 1.5;
  }

  .note-title {
    font-size: 1.18rem;
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .note-title:hover {
    color: var(--accent);
  }

  .view-all {
    display: inline-block;
    font-size: 1rem;
    font-weight: 500;
    color: var(--accent);
  }

  .contact-links {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1.09rem;
  }

  .contact-links a {
    color: var(--accent);
  }

  .dot {
    color: var(--text-tertiary);
  }

  @media (max-width: 640px) {
    .home-hero h1 {
      font-size: 2.27rem;
    }
  }
</style>