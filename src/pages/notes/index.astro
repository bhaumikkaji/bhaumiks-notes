---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes');
const notes = allNotes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const categories = [...new Set(notes.map(n => n.data.category))];
---

<BaseLayout title="Notes" description="Notes on tech, design, and AI by Bhaumik Kaji." showScrollProgress={true}>
  <div class="notes-page">
    <div class="notes-header">
      <h1>Notes</h1>
      <p>Writing about tech, design, and AI — born out of empirical learnings and everyday observations.</p>
    </div>

    <div class="notes-filter">
      <button class="filter-btn active" data-filter="all">All</button>
      {categories.map((cat) => (
        <button class="filter-btn" data-filter={cat}>{cat}</button>
      ))}
    </div>

    <div class="notes-list">
      {notes.map((note) => (
        <a href={`/notes/${note.data.slug}`} class="note-card" data-category={note.data.category}>
          <div class="note-card-top">
            <span class="note-category">{note.data.category}</span>
            <span class="note-date">{note.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
          </div>
          <h2 class="note-title">{note.data.title}</h2>
          <p class="note-summary">{note.data.summary || note.data.description}</p>
          <span class="note-cta">Read →</span>
        </a>
      ))}
    </div>
  </div>

  <script is:inline>
    const filterBtns = document.querySelectorAll('.notes-filter .filter-btn');
    const cards = document.querySelectorAll('.note-card');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        cards.forEach((card, i) => {
          const show = filter === 'all' || card.dataset.category === filter;
          if (show) {
            card.style.display = '';
            card.style.animation = `fadeUp 0.25s ease ${i * 0.03}s both`;
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  </script>
</BaseLayout>

<style>
  .notes-page {
    padding-top: 40px;
    padding-bottom: 60px;
  }

  .notes-header {
    margin-bottom: 32px;
  }

  .notes-header h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 10px;
  }

  .notes-header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.5;
  }

  .notes-filter {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .filter-btn {
    padding: 4px 12px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: transparent;
    color: var(--text-tertiary);
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;
    font-family: inherit;
  }

  .filter-btn:hover {
    border-color: var(--text-tertiary);
    color: var(--text-secondary);
  }

  .filter-btn.active {
    border-color: var(--accent);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .notes-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .note-card {
    display: block;
    padding: 18px 20px;
    border: 1px solid var(--border);
    border-radius: 14px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }

  .note-card:hover {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
    background: color-mix(in srgb, var(--text-primary) 4%, transparent);
    transform: translateY(-1px);
  }

  .note-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .note-category {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 2px 10px;
    border-radius: 12px;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .note-date {
    font-size: 0.85rem;
    color: var(--text-tertiary);
  }

  .note-title {
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 6px;
    line-height: 1.3;
  }

  .note-summary {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 8px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .note-cta {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 640px) {
    .notes-header h1 {
      font-size: 1.6rem;
    }

    .note-card {
      padding: 14px 16px;
    }
  }
</style>