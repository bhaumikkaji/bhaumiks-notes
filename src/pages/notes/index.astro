---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryPill from '../../components/CategoryPill.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes');
const notes = allNotes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = notes.slice(0, 3);
---

<BaseLayout title="Notes on tech, design & AI." description="Notes on tech, design and AI by Bhaumik Kaji. Born out of empirical learnings and everyday observations.">
  <div class="notes-page">
    <div class="notes-intro">
      <h1>Notes on tech, design & AI.</h1>
      <p class="intro-text">These are my notes — like a semi-frequently updated journal. Everything I write is born out of empirical learnings and everyday observations. There's obviously bias in these notes, but since honest personal accounts from people in tech are rare, I hope this serves as a useful one.</p>
      <p class="intro-cta">After reading, if you have a different perspective, feel free to ping me on <a href="https://twitter.com/bhaumikkaji">Twitter</a> or email <strong>bhaumik@bhaumikkaji.com</strong>.</p>
    </div>

    <div class="about-card">
      <p>Senior Product Designer at <strong>Microsoft</strong> — Copilot, Teams, Office Mobile. I write about product, design, and AI from empirical learnings.</p>
    </div>

    <div class="notes-featured">
      <h2 class="section-label">Start reading here</h2>
      <div class="notes-list">
        {featured.map((note) => (
          <div class="note-entry">
            <a href={`/notes/${note.data.slug}`} class="note-title">{note.data.title}</a>
            <CategoryPill category={note.data.category} />
          </div>
        ))}
      </div>
    </div>

    <hr class="divider" />

    <div class="notes-list">
      {notes.map((note) => (
        <div class="note-entry">
          <a href={`/notes/${note.data.slug}`} class="note-title">{note.data.title}</a>
          <CategoryPill category={note.data.category} />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .notes-page {
    padding-top: 40px;
  }

  .notes-intro {
    margin-bottom: 64px;
  }

  .notes-intro h1 {
    font-size: 2.27rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 20px;
  }

  .intro-text {
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 12px;
    font-size: 1.18rem;
  }

  .intro-cta {
    color: var(--text-secondary);
    line-height: 1.65;
    font-size: 1.09rem;
  }

  .intro-cta a {
    color: var(--accent);
  }

  .about-card {
    background: color-mix(in srgb, var(--text-primary) 4%, transparent);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px 24px;
    margin-bottom: 48px;
  }

  .about-card p {
    color: var(--text-secondary);
    line-height: 1.55;
    font-size: 1rem;
    margin: 0;
  }

  .about-card p strong {
    color: var(--text-primary);
  }

  .notes-featured {
    margin-bottom: 48px;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: 20px;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 48px 0;
  }

  .notes-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .note-entry {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
    line-height: 1.5;
  }

  .note-title {
    font-size: 1.18rem;
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .note-title:hover {
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .notes-intro h1 {
      font-size: 1.9rem;
    }
  }
</style>