---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes');
const notes = allNotes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
// Flatten categories: if array, use first tag; collect unique tags for filter buttons
const allTags = notes.flatMap(n => Array.isArray(n.data.category) ? n.data.category : [n.data.category]);
const categories = [...new Set(allTags)];
---

<BaseLayout title="Index" description="Notes on tech, design, and AI by Bhaumik Kaji." showScrollProgress={true}>
  <div class="notes-page">
    <div class="notes-intro">
      <h1>Index</h1>
      <p class="intro-tagline">Notes on tech, design, and AI by Bhaumik Kaji.</p>
    </div>

    <div class="notes-filter">
      <button class="filter-btn active" data-filter="all" aria-pressed="true">All</button>
      {categories.map((cat) => (
        <button class="filter-btn" data-filter={cat} aria-pressed="false">{cat}</button>
      ))}
    </div>

    <div class="notes-list">
        {notes.map((note) => {
          const primaryCat = Array.isArray(note.data.category) ? note.data.category[0] : note.data.category;
          const allCats = Array.isArray(note.data.category) ? note.data.category.join(',') : note.data.category;
          return (
            <div class="note-entry" data-category={allCats} data-slug={note.data.slug}>
              <a href={`/notes/${note.data.slug}`} class="note-title">{note.data.title}</a>
              <span class="note-category-pill">{primaryCat}</span>
              <div class="note-reactions" data-slug={note.data.slug}></div>
            </div>
          );
        })}
    </div>
  </div>

  <script is:inline>
    const filterBtns = document.querySelectorAll('.notes-filter .filter-btn');
    const entries = document.querySelectorAll('.note-entry');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;
        filterBtns.forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');

        entries.forEach(entry => {
          const cats = entry.dataset.category || '';
          entry.style.display = (filter === 'all' || cats.split(',').includes(filter)) ? '' : 'none';
        });
      });
    });

    // Populate reaction counts from localStorage
    var STORAGE_KEY = 'bkn-reactions';

    function renderIndexReactions() {
      var store = {};
      try { store = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch(e) {}

      document.querySelectorAll('.note-reactions').forEach(function(el) {
        var slug = el.dataset.slug;
        if (!slug) return;
        var myReactions = store[slug] || {};
        var count = Object.keys(myReactions).length;
        el.innerHTML = '';

        if (count > 0) {
          var span = document.createElement('span');
          span.className = 'reaction-icon';
          span.innerHTML = '<svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg> ' + count;
          el.appendChild(span);
        }
      });
    }

    renderIndexReactions();

    // Re-render when returning to this page (in case reactions changed)
    window.addEventListener('focus', renderIndexReactions);
  </script>
</BaseLayout>

<style>
  .notes-page {
    padding-top: 40px;
    padding-bottom: 60px;
  }

  .notes-intro {
    margin-bottom: 40px;
  }

  .notes-intro h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 8px;
  }

  .intro-tagline {
    font-size: 1.2rem;
    color: var(--text-secondary);
    margin-bottom: 16px;
    font-weight: 400;
  }

  .notes-filter {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .filter-btn {
    padding: 4px 12px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: transparent;
    color: var(--text-tertiary);
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.15s ease;
    font-family: inherit;
  }

  .filter-btn:hover {
    border-color: var(--text-tertiary);
    color: var(--text-secondary);
  }

  .filter-btn.active {
    border-color: var(--accent);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .notes-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .note-entry {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
    padding: 12px 0;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
    line-height: 1.5;
    transition: background 0.15s ease;
    justify-content: space-between;
  }

  .note-entry:last-child {
    border-bottom: none;
  }

  .note-title {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.15s ease;
    flex: 1;
  }

  .note-category-pill {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 8px;
    border-radius: 10px;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    white-space: nowrap;
  }

  .note-title:hover {
    color: var(--accent);
  }

  .note-reactions {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }

  .note-reactions .reaction-icon {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 0.7rem;
    color: var(--text-tertiary);
  }

  .note-reactions .reaction-icon :global(svg) {
    width: 11px;
    height: 11px;
  }

  @media (max-width: 640px) {
    .notes-intro h1 {
      font-size: 1.6rem;
    }

    .notes-page {
      padding: 24px 0;
    }
  }
</style>