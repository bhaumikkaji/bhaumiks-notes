---
import { getCollection, render } from 'astro:content';
import NoteLayout from '../../layouts/NoteLayout.astro';
import ReadMore from '../../components/ReadMore.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({
    params: { slug: note.data.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);

const allNotes = await getCollection('notes');
const relatedNotes = allNotes
  .filter((n) => n.data.slug !== note.data.slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
const audioPath = `/audio/${note.data.slug}.mp3`;

---

<NoteLayout title={note.data.title} description={note.data.description} category={note.data.category} slug={note.data.slug} tldr={note.data.tldr} audio={audioPath}>
  <Content />
  <ReadMore notes={relatedNotes} />
</NoteLayout>