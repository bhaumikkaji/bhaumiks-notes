---
import BaseLayout from '../layouts/BaseLayout.astro';

const resources = [
  {
    name: 'Lucide Icons',
    url: 'https://github.com/lucide-icons/lucide',
    description: 'Beautiful, consistent icon toolkit. 1,800+ open-source SVG icons with React, Vue, and Svelte support. ISC licensed.',
    tag: 'Design',
  },
  {
    name: 'Astro',
    url: 'https://github.com/withastro/astro',
    description: 'The web framework for content-driven websites. Ship less JavaScript, build faster sites, and enjoy the best developer experience.',
    tag: 'Framework',
  },
  {
    name: 'shadcn/ui',
    url: 'https://github.com/shadcn-ui/ui',
    description: 'Beautifully designed components built with Radix and Tailwind CSS. Copy and paste into your apps — not a dependency.',
    tag: 'Design',
  },
  {
    name: 'Tailwind CSS',
    url: 'https://github.com/tailwindlabs/tailwindcss',
    description: 'A utility-first CSS framework for rapid UI development. Packed with classes that can be composed to build any design.',
    tag: 'CSS',
  },
  {
    name: 'Pretext',
    url: 'https://github.com/chenglou/pretext',
    description: 'Interesting text layout engine exploring new paradigms for how we interact with written content on screens.',
    tag: 'Typography',
  },
  {
    name: 'Vercel AI SDK',
    url: 'https://github.com/vercel/ai',
    description: 'The AI toolkit for building AI-powered apps with React, Next.js, Vue, Svelte, and more. Streaming, tool calling, and RAG built in.',
    tag: 'AI',
  },
  {
    name: 'OpenProps',
    url: 'https://github.com/argyleink/open-props',
    description: 'Super-charged CSS custom properties. A set of expertly crafted CSS custom properties for design systems and rapid prototyping.',
    tag: 'CSS',
  },
  {
    name: 'Motion',
    url: 'https://github.com/motiondivision/motion',
    description: 'A modern animation library for React and the web. Animate anything with a minimal API. Production-ready by default.',
    tag: 'Animation',
  },
  {
    name: 'MDX',
    url: 'https://github.com/mdx-js/mdx',
    description: 'Markdown for the component era. Use JSX in your markdown, import components, and export metadata. The best of both worlds.',
    tag: 'Content',
  },
  {
    name: 'Phosphor Icons',
    url: 'https://github.com/phosphor-icons/homepage',
    description: 'Flexible icon family for interfaces, diagrams, and presentations. 9,000+ icons in 6 weights. MIT licensed.',
    tag: 'Design',
  },
];

const tags = [...new Set(resources.map(r => r.tag))];
---

<BaseLayout title="Resources ・ Bhaumik.sudo" description="Curated collection of tools, libraries, and repositories that inspire and inform my work." showScrollProgress={true}>
  <div class="resources-page">
    <div class="resources-header">
      <h1>Resources</h1>
      <p>Tools, libraries, and repos I find interesting. No personal info here — just things worth sharing.</p>
    </div>

    <div class="resources-filter" id="resources-filter">
      <button class="filter-btn active" data-filter="all">All</button>
      {tags.map((tag) => (
        <button class="filter-btn" data-filter={tag}>{tag}</button>
      ))}
    </div>

    <div class="resources-list">
      {resources.map((resource) => (
        <a href={resource.url} class="resource-card" data-tag={resource.tag} target="_blank" rel="noopener noreferrer">
          <span class="resource-tag">{resource.tag}</span>
          <h3 class="resource-name">{resource.name}</h3>
          <p class="resource-desc">{resource.description}</p>
          <span class="resource-link">{new URL(resource.url).hostname.replace('github.com/', 'github.com/')} →</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<script is:inline>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.resource-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      cards.forEach(card => {
        if (filter === 'all' || card.dataset.tag === filter) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .resources-page {
    padding-top: 40px;
    padding-bottom: 60px;
  }

  .resources-header {
    margin-bottom: 32px;
  }

  .resources-header h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 12px;
  }

  .resources-header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.5;
  }

  .resources-filter {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .filter-btn {
    padding: 5px 14px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: transparent;
    color: var(--text-tertiary);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .filter-btn:hover {
    border-color: var(--text-tertiary);
    color: var(--text-secondary);
  }

  .filter-btn.active {
    border-color: var(--accent);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .resources-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .resource-card {
    display: block;
    padding: 20px 24px;
    border: 1px solid var(--border);
    border-radius: 14px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .resource-card:hover {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
    background: color-mix(in srgb, var(--text-primary) 4%, transparent);
  }

  .resource-tag {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 10px;
    border-radius: 12px;
    margin-bottom: 10px;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .resource-name {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 6px;
  }

  .resource-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 10px;
  }

  .resource-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .resources-header h1 {
      font-size: 1.6rem;
    }

    .resource-card {
      padding: 16px 18px;
    }
  }
</style>