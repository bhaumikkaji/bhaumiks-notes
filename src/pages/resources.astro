---
import BaseLayout from '../layouts/BaseLayout.astro';

const resources = [
  {
    name: 'Paperclip',
    url: 'https://github.com/paperclipai/paperclip',
    description: 'Node.js server + React UI that orchestrates AI agents into a company structure. A control plane above runtimes like OpenClaw, Claude Code, Codex, and Cursor.',
    tag: 'AI',
  },
  {
    name: 'GBrain',
    url: 'https://github.com/garrytan/gbrain',
    description: "Garry Tan's self-wiring knowledge graph + hybrid search + 26 skills for persistent agent memory. 9.7K stars, built in 12 days, MIT licensed.",
    tag: 'AI',
  },
  {
    name: 'Career-Ops',
    url: 'https://github.com/santifer/career-ops',
    description: 'AI-powered job search system with 14 skill modes, ATS-optimized PDF generation, portal scanning, and batch evaluation. Built on Claude Code and Gemini CLI.',
    tag: 'AI',
  },
  {
    name: 'Cognee',
    url: 'https://github.com/topoteretes/cognee',
    description: 'Memory and knowledge management layer for AI systems. Graph-based retrieval with vector databases.',
    tag: 'AI',
  },
  {
    name: 'Scrapling',
    url: 'https://github.com/D4Vinci/Scrapling',
    description: 'High-performance web scraping library with anti-detection features. Built for resilience.',
    tag: 'Dev Tools',
  },
  {
    name: 'Caveman',
    url: 'https://github.com/JuliusBrussee/caveman',
    description: 'Minimalist knowledge management. Local-first, markdown-based personal wiki.',
    tag: 'Knowledge',
  },
  {
    name: 'Design Extract',
    url: 'https://github.com/Manavarya09/design-extract',
    description: 'Extract design tokens and styles from any URL. Useful for design system research.',
    tag: 'Design',
  },
  {
    name: 'MetaClaw',
    url: 'https://github.com/aiming-lab/MetaClaw',
    description: 'AI agent framework with tool-use capabilities. Open-source alternative for agentic workflows.',
    tag: 'AI',
  },
  {
    name: 'Browser Harness',
    url: 'https://github.com/browser-use/browser-harness',
    description: 'Browser automation framework designed for AI agents. Headless control with cognitive overlays.',
    tag: 'AI',
  },
  {
    name: 'Paseo',
    url: 'https://github.com/getpaseo/paseo',
    description: 'E2E testing framework with natural language test specs. Write tests in plain English.',
    tag: 'Dev Tools',
  },
  {
    name: 'Awesome OpenClaw Usecases',
    url: 'https://github.com/hesamsheikh/awesome-openclaw-usecases',
    description: 'Curated list of OpenClaw use cases and patterns. Community-driven.',
    tag: 'OpenClaw',
  },
  {
    name: 'Awesome Claude Code',
    url: 'https://github.com/hesreallyhim/awesome-claude-code',
    description: 'Curated list of Claude Code tips, patterns, and workflows. Essential reference.',
    tag: 'AI',
  },
  {
    name: 'OMLX',
    url: 'https://github.com/jundot/omlx',
    description: 'Open machine learning exchange. Tools for model comparison and benchmarking.',
    tag: 'ML',
  },
  {
    name: 'Memex',
    url: 'https://github.com/memex-lab/memex',
    description: 'Personal knowledge engine. Capture, organize, and retrieve anything you\'ve seen online.',
    tag: 'Knowledge',
  },
  {
    name: 'Mempalace',
    url: 'https://github.com/milla-jovovich/mempalace',
    description: 'Memory palace technique for AI. Structured spatial memory for LLM agents.',
    tag: 'AI',
  },
  {
    name: 'PureMac',
    url: 'https://github.com/momenbasel/PureMac',
    description: 'Curated list of the best macOS apps. Quality over quantity curation.',
    tag: 'Mac',
  },
  {
    name: 'Pixel Agents',
    url: 'https://github.com/pablodelucca/pixel-agents',
    description: 'Multi-modal AI agents with pixel-level understanding. Vision-first approach.',
    tag: 'AI',
  },
  {
    name: 'OpenClaw Claude Bridge',
    url: 'https://github.com/tomatobdev/openclaw-claude-bridge',
    description: 'Bridge between OpenClaw and Claude. Integration patterns for agent workflows.',
    tag: 'OpenClaw',
  },
  {
    name: 'The Book of Secret Knowledge',
    url: 'https://github.com/trimstray/the-book-of-secret-knowledge',
    description: 'Massive curated collection of guides, tools, and resources for developers and ops.',
    tag: 'Dev Tools',
  },
  {
    name: 'Mac Code',
    url: 'https://github.com/walter-grace/mac-code',
    description: 'Setup scripts and configs for macOS development environments. Opinionated and thorough.',
    tag: 'Mac',
  },
  {
    name: 'Clicky',
    url: 'https://github.com/farzaa/clicky',
    description: 'Keyboard-driven productivity launcher for macOS. Fast, minimal, extensible.',
    tag: 'Mac',
  },
  {
    name: 'Build Your Own OpenClaw',
    url: 'https://github.com/czl9707/build-your-own-openclaw',
    description: 'Step-by-step guide to building an OpenClaw-compatible agent from scratch.',
    tag: 'OpenClaw',
  },
  {
    name: 'LLMFit',
    url: 'https://github.com/AlexsJones/llmfit',
    description: 'Fine-tuning toolkit for large language models. Simplified training pipelines.',
    tag: 'ML',
  },
];

const tags = [...new Set(resources.map(r => r.tag))];
---

<BaseLayout title="Resources" description="Interesting repos and tools worth revisiting." showScrollProgress={true}>
  <div class="resources-page">
    <div class="resources-header">
      <h1>Resources</h1>
      <p>Repos and tools I find interesting. No personal info here — just things worth sharing and revisiting.</p>
    </div>

    <div class="resources-filter">
      <button class="filter-btn active" data-filter="all" aria-pressed="true">All</button>
      {tags.map((tag) => (
        <button class="filter-btn" data-filter={tag} aria-pressed="false">{tag}</button>
      ))}
    </div>

    <div class="resources-list">
      {resources.map((resource) => (
        <a href={resource.url} class="resource-entry" data-tag={resource.tag} target="_blank" rel="noopener noreferrer">
          <div class="resource-main">
            <div class="resource-top">
              <span class="resource-name">{resource.name}</span>
            </div>
            <p class="resource-desc">{resource.description}</p>
          </div>
          <span class="resource-arrow">↗</span>
        </a>
      ))}
    </div>
  </div>

  <script is:inline>
    const filterBtns = document.querySelectorAll('.resources-filter .filter-btn');
    const entries = document.querySelectorAll('.resource-entry');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;
        filterBtns.forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
        entries.forEach(entry => {
          entry.style.display = (filter === 'all' || entry.dataset.tag === filter) ? '' : 'none';
        });
      });
    });
  </script>
</BaseLayout>

<style>
  .resources-page {
    padding-top: 40px;
    padding-bottom: 60px;
  }

  .resources-header {
    margin-bottom: 32px;
  }

  .resources-header h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 8px;
  }

  .resources-header p {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.5;
  }

  .resources-filter {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .filter-btn {
    padding: 4px 12px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: transparent;
    color: var(--text-tertiary);
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.15s ease;
    font-family: inherit;
  }

  .filter-btn:hover {
    border-color: var(--text-tertiary);
    color: var(--text-secondary);
  }

  .filter-btn.active {
    border-color: var(--accent);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .resources-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .resource-entry {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
    text-decoration: none;
    color: inherit;
    transition: color 0.15s ease;
  }

  .resource-entry:last-child {
    border-bottom: none;
  }

  .resource-entry:hover {
    color: var(--accent);
  }

  .resource-main {
    flex: 1;
    min-width: 0;
  }

  .resource-top {
    margin-bottom: 2px;
  }

  .resource-name {
    font-size: 0.95rem;
    font-weight: 500;
  }

  .resource-desc {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.45;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .resource-arrow {
    color: var(--text-tertiary);
    font-size: 0.8rem;
    flex-shrink: 0;
  }

  .resource-entry:hover .resource-arrow {
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .resources-header h1 {
      font-size: 1.6rem;
    }

    .resources-page {
      padding: 24px 0;
    }
  }
</style>