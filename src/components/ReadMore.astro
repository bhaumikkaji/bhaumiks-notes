---
export interface Props {
  notes: Array<{
    slug: string;
    title: string;
    description: string;
    category: string | string[];
    pubDate: Date;
  }>;
}

const { notes } = Astro.props;
---

{notes.length > 0 && (
  <div class="read-more">
    <span class="section-label">Read more</span>
    <div class="read-more-list">
      {notes.map((note) => (
        <div class="read-more-entry">
          <a href={`/notes/${note.data.slug}`} class="read-more-title">{note.data.title}</a>
        </div>
      ))}
    </div>
  </div>
)}

<style>
  .read-more {
    margin-top: 80px;
    padding-top: 48px;
    border-top: 1px solid var(--border);
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: 20px;
  }

  .read-more-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .read-more-entry {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
    line-height: 1.5;
  }

  .read-more-title {
    font-size: 1.09rem;
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .read-more-title:hover {
    color: var(--accent);
  }
</style>