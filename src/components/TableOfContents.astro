---
// Interactive table of contents — extracted from rendered note headings
// Only appears when h2/h3 headings exist; hidden otherwise
// Sticky sidebar that follows scroll; highlights current section
---

<nav class="toc" id="toc" aria-label="Table of contents">
  <span class="toc-label">Chapters</span>
  <ul class="toc-list" id="toc-list"></ul>
</nav>

<style>
  .toc {
    position: sticky;
    top: 80px;
  }

  .toc-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: 12px;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-list li {
    margin-bottom: 0;
  }

  .toc-list a {
    display: block;
    padding: 4px 0;
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--text-tertiary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .toc-list a:hover {
    color: var(--text-secondary);
  }

  .toc-list a.active {
    color: var(--accent);
    font-weight: 500;
  }

  /* h3 entries — indented */
  .toc-list a.toc-h3 {
    padding-left: 12px;
    font-size: 0.73rem;
  }

  @media (max-width: 1024px) {
    .toc {
      display: none;
    }
  }
</style>

<script is:inline>
  (function() {
    function buildTOC() {
      var noteBody = document.querySelector('.note-body');
      var tocList = document.getElementById('toc-list');
      var tocNav = document.getElementById('toc');
      var sidebar = document.querySelector('.note-sidebar');
      if (!noteBody || !tocList || !tocNav) return;

      var headings = noteBody.querySelectorAll('h2, h3');
      if (headings.length === 0) {
        tocNav.style.display = 'none';
        if (sidebar) sidebar.style.display = 'none';
        var layout = document.querySelector('.note-layout');
        if (layout) layout.style.gridTemplateColumns = '1fr';
        return;
      }

      // Restore if previously hidden
      if (sidebar) sidebar.style.display = '';
      var layout = document.querySelector('.note-layout');
      if (layout) layout.style.gridTemplateColumns = '';
      tocNav.style.display = '';

      // Build list
      tocList.innerHTML = '';
      headings.forEach(function(heading, i) {
        if (!heading.id) {
          heading.id = 'section-' + i + '-' + heading.textContent.toLowerCase().replace(/[^\w]+/g, '-').replace(/^-|-$/g, '');
        }

        var li = document.createElement('li');
        var a = document.createElement('a');
        a.href = '#' + heading.id;
        a.textContent = heading.textContent.trim();
        a.classList.add(heading.tagName === 'H3' ? 'toc-h3' : 'toc-h2');
        a.dataset.headingId = heading.id;

        a.addEventListener('click', function(e) {
          e.preventDefault();
          heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });

        li.appendChild(a);
        tocList.appendChild(li);
      });

      // IntersectionObserver for active highlight
      var observer = new IntersectionObserver(function(entries) {
        var currentId = null;
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            currentId = entry.target.id;
          }
        });
        // Fallback: find heading closest to top
        if (!currentId) {
          var closestDist = Infinity;
          headings.forEach(function(h) {
            var rect = h.getBoundingClientRect();
            if (rect.top < 200 && Math.abs(rect.top - 80) < closestDist) {
              closestDist = Math.abs(rect.top - 80);
              currentId = h.id;
            }
          });
        }
        tocList.querySelectorAll('a').forEach(function(a) {
          a.classList.toggle('active', a.dataset.headingId === currentId);
        });
      }, {
        root: null,
        rootMargin: '-80px 0px -60% 0px',
        threshold: 0
      });

      headings.forEach(function(h) { observer.observe(h); });
    }

    // Wait for DOM then build
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', buildTOC);
    } else {
      buildTOC();
    }
  })();
</script>