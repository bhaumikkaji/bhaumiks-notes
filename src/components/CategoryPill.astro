---
export interface Props {
  category: string;
}

const { category } = Astro.props;

const categoryColors: Record<string, string> = {
  'Tech': '#3b82f6',
  'Design': '#8b5cf6',
  'AI': '#f59e0b',
  'Career': '#10b981',
  'Observations': '#6b7280',
  'Life': '#ec4899',
};

const color = categoryColors[category] || '#6b7280';
---

<span class="category-pill" style={`--pill-color: ${color}`}>{category}</span>

<style>
  .category-pill {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--pill-color);
    background: color-mix(in srgb, var(--pill-color) 10%, transparent);
    padding: 2px 8px;
    border-radius: 10px;
    white-space: nowrap;
  }
</style>