---
export interface Props {
  category: string;
}

const { category } = Astro.props;
---

<span class="category-pill">
  {category}
</span>

<style>
  .category-pill {
    display: inline-flex;
    align-items: center;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 12px;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    line-height: 1.6;
    white-space: nowrap;
  }
</style>