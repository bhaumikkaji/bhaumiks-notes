---
import Icon from './Icon.astro';

const themes = [
  { id: 'ember', label: 'Ember', dark: '#fb923c', gradient: false },
  { id: 'electric', label: 'Electric', dark: '#60a5fa', gradient: false },
  { id: 'violet', label: 'Violet', dark: '#a78bfa', gradient: false },
  { id: 'emerald', label: 'Emerald', dark: '#34d399', gradient: false },
  { id: 'rose', label: 'Rose', dark: '#f472b6', gradient: false },
  { id: 'sunset', label: 'Sunset', dark: 'linear-gradient(135deg, #fb923c, #f472b6)', gradient: true },
  { id: 'aurora', label: 'Aurora', dark: 'linear-gradient(135deg, #22d3ee, #a78bfa)', gradient: true },
  { id: 'lava', label: 'Lava', dark: 'linear-gradient(135deg, #f87171, #fbbf24)', gradient: true },
];
---

<span class="personalize-wrapper">
  <button class="personalize-trigger" id="personalize-trigger" aria-label="Customize theme">
    <Icon name="palette" size={16} />
  </button>

  <div class="personalize-panel" id="personalize-panel">
    <div class="panel-header">
      <span class="panel-title">Theme</span>
      <button class="panel-close" id="panel-close" aria-label="Close">
        <Icon name="x" size={14} />
      </button>
    </div>

    <div class="theme-grid">
      {themes.map((theme) => (
        <button
          class={`theme-swatch ${theme.gradient ? 'swatch-gradient' : 'swatch-solid'}`}
          data-theme-id={theme.id}
          aria-label={theme.label}
          title={theme.label}
          style={theme.gradient
            ? `background: ${theme.dark}`
            : `background: ${theme.dark}`
          }
        >
          <span class="swatch-check"><Icon name="check" size={10} /></span>
        </button>
      ))}
    </div>

    <div class="mode-section">
      <button class="mode-btn" data-mode="light" aria-label="Light mode">
        <Icon name="sun" size={14} />
      </button>
      <button class="mode-btn" data-mode="dark" aria-label="Dark mode">
        <Icon name="moon" size={14} />
      </button>
    </div>
  </div>
</span>

<style>
  .personalize-wrapper {
    position: relative;
    display: inline-flex;
  }

  .personalize-trigger {
    background: none;
    border: none;
    color: var(--text-tertiary);
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s ease;
  }

  .personalize-trigger:hover {
    color: var(--accent);
  }

  .personalize-trigger :global(svg) {
    display: block;
  }

  .personalize-panel {
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 8px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 16px;
    min-width: 200px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    opacity: 0;
    transform: translateY(-4px) scale(0.97);
    pointer-events: none;
    transition: opacity 0.15s ease, transform 0.15s ease;
    z-index: 1000;
  }

  .personalize-panel.open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .panel-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
  }

  .panel-close {
    background: none;
    border: none;
    color: var(--text-tertiary);
    cursor: pointer;
    padding: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s ease;
  }

  .panel-close:hover {
    color: var(--text-primary);
  }

  .panel-close :global(svg) {
    display: block;
  }

  .theme-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
    margin-bottom: 12px;
  }

  .theme-swatch {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    border: 2px solid transparent;
    cursor: pointer;
    position: relative;
    transition: border-color 0.15s ease, transform 0.15s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .theme-swatch:hover {
    transform: scale(1.08);
  }

  .theme-swatch.active {
    border-color: var(--text-primary);
  }

  .swatch-gradient {
    background-size: 100% 100%;
  }

  .swatch-check {
    display: none;
    color: white;
  }

  .theme-swatch.active .swatch-check {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .swatch-check :global(svg) {
    display: block;
  }

  .mode-section {
    display: flex;
    gap: 6px;
  }

  .mode-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-tertiary);
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
  }

  .mode-btn:hover {
    border-color: var(--text-tertiary);
    color: var(--text-secondary);
  }

  .mode-btn.active {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent);
  }

  .mode-btn :global(svg) {
    display: block;
  }
</style>

<script is:inline>
  const themes = {
    ember:    { light: { accent: '#c2410c', accentHover: '#a83608' }, dark: { accent: '#fb923c', accentHover: '#f97316' } },
    electric: { light: { accent: '#2563eb', accentHover: '#1d4ed8' }, dark: { accent: '#60a5fa', accentHover: '#3b82f6' } },
    violet:   { light: { accent: '#7c3aed', accentHover: '#6d28d9' }, dark: { accent: '#a78bfa', accentHover: '#8b5cf6' } },
    emerald:  { light: { accent: '#059669', accentHover: '#047857' }, dark: { accent: '#34d399', accentHover: '#10b981' } },
    rose:     { light: { accent: '#db2777', accentHover: '#be185d' }, dark: { accent: '#f472b6', accentHover: '#ec4899' } },
    sunset:   { light: { accent: '#f97316', accentHover: '#ea580c', gf: '#f97316', gt: '#ec4899' }, dark: { accent: '#fb923c', accentHover: '#f97316', gf: '#fb923c', gt: '#f472b6' } },
    aurora:   { light: { accent: '#06b6d4', accentHover: '#0891b2', gf: '#06b6d4', gt: '#8b5cf6' }, dark: { accent: '#22d3ee', accentHover: '#06b6d4', gf: '#22d3ee', gt: '#a78bfa' } },
    lava:     { light: { accent: '#ef4444', accentHover: '#dc2626', gf: '#ef4444', gt: '#f59e0b' }, dark: { accent: '#f87171', accentHover: '#ef4444', gf: '#f87171', gt: '#fbbf24' } },
  };

  function applyTheme(themeId, mode) {
    const theme = themes[themeId];
    if (!theme) return;
    const c = theme[mode] || theme.dark;
    const r = document.documentElement.style;
    r.setProperty('--accent', c.accent);
    r.setProperty('--accent-hover', c.accentHover);
    if (c.gf) {
      r.setProperty('--accent-gradient', 'linear-gradient(135deg,' + c.gf + ',' + c.gt + ')');
      r.setProperty('--accent-gradient-from', c.gf);
      r.setProperty('--accent-gradient-to', c.gt);
    } else {
      r.setProperty('--accent-gradient', c.accent);
      r.setProperty('--accent-gradient-from', c.accent);
      r.setProperty('--accent-gradient-to', c.accentHover);
    }
    document.documentElement.setAttribute('data-theme', themeId);
    document.documentElement.setAttribute('data-mode', mode);
    if (mode === 'dark') {
      r.setProperty('--bg', '#111111');
      r.setProperty('--text-primary', '#f0f0f0');
      r.setProperty('--text-secondary', '#a0a0a0');
      r.setProperty('--text-tertiary', '#666666');
      r.setProperty('--border', '#2a2a2a');
    } else {
      r.setProperty('--bg', '#fafafa');
      r.setProperty('--text-primary', '#111111');
      r.setProperty('--text-secondary', '#555555');
      r.setProperty('--text-tertiary', '#888888');
      r.setProperty('--border', '#e8e8e8');
    }
    const pb = document.getElementById('scroll-progress');
    if (pb) pb.style.background = c.gf ? 'linear-gradient(90deg,' + c.gf + ',' + c.gt + ')' : 'linear-gradient(90deg,' + c.accent + ',' + c.accentHover + ')';
    localStorage.setItem('theme', themeId);
    localStorage.setItem('mode', mode);
    document.querySelectorAll('.theme-swatch').forEach(b => b.classList.toggle('active', b.dataset.themeId === themeId));
    document.querySelectorAll('.mode-btn').forEach(b => b.classList.toggle('active', b.dataset.mode === mode));
  }

  const storedTheme = localStorage.getItem('theme') || 'ember';
  const storedMode = localStorage.getItem('mode') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
  applyTheme(storedTheme, storedMode);

  const trigger = document.getElementById('personalize-trigger');
  const panel = document.getElementById('personalize-panel');
  const close = document.getElementById('panel-close');

  trigger.addEventListener('click', (e) => { e.stopPropagation(); panel.classList.toggle('open'); });
  close.addEventListener('click', () => panel.classList.remove('open'));
  document.addEventListener('click', (e) => { if (!panel.contains(e.target) && !trigger.contains(e.target)) panel.classList.remove('open'); });

  document.querySelectorAll('.theme-swatch').forEach(btn => {
    btn.addEventListener('click', () => {
      const themeId = btn.dataset.themeId;
      const currentMode = document.documentElement.getAttribute('data-mode') || 'light';
      applyTheme(themeId, currentMode);
    });
  });

  document.querySelectorAll('.mode-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const mode = btn.dataset.mode;
      const currentTheme = document.documentElement.getAttribute('data-theme') || 'ember';
      applyTheme(currentTheme, mode);
    });
  });
</script>