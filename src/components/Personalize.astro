---
import Icon from './Icon.astro';

// Theme definitions
const themes = [
  { id: 'ember', label: 'Ember', type: 'solid', light: '#c2410c', dark: '#fb923c', gradient: false },
  { id: 'electric', label: 'Electric', type: 'solid', light: '#2563eb', dark: '#60a5fa', gradient: false },
  { id: 'violet', label: 'Violet', type: 'solid', light: '#7c3aed', dark: '#a78bfa', gradient: false },
  { id: 'emerald', label: 'Emerald', type: 'solid', light: '#059669', dark: '#34d399', gradient: false },
  { id: 'rose', label: 'Rose', type: 'solid', light: '#db2777', dark: '#f472b6', gradient: false },
  { id: 'sunset', label: 'Sunset', type: 'gradient', light: 'linear-gradient(135deg, #f97316, #ec4899)', dark: 'linear-gradient(135deg, #fb923c, #f472b6)', gradient: true },
  { id: 'aurora', label: 'Aurora', type: 'gradient', light: 'linear-gradient(135deg, #06b6d4, #8b5cf6)', dark: 'linear-gradient(135deg, #22d3ee, #a78bfa)', gradient: true },
  { id: 'lava', label: 'Lava', type: 'gradient', light: 'linear-gradient(135deg, #ef4444, #f59e0b)', dark: 'linear-gradient(135deg, #f87171, #fbbf24)', gradient: true },
];
---

<div class="personalize-trigger" id="personalize-trigger">
  <button class="trigger-btn" id="trigger-btn" aria-label="Customize theme">
    <Icon name="palette" size={18} />
  </button>
</div>

<div class="personalize-panel" id="personalize-panel">
  <div class="panel-header">
    <span class="panel-title">Personalize</span>
    <button class="panel-close" id="panel-close" aria-label="Close">
      <Icon name="x" size={16} />
    </button>
  </div>

  <div class="panel-section">
    <span class="section-label">Theme</span>
    <div class="theme-grid">
      {themes.map((theme) => (
        <button
          class={`theme-swatch ${theme.gradient ? 'swatch-gradient' : 'swatch-solid'}`}
          data-theme-id={theme.id}
          aria-label={theme.label}
          title={theme.label}
          style={theme.gradient
            ? `background: ${theme.dark}`
            : `background: ${theme.dark}`
          }
        >
          <span class="swatch-check">
            <Icon name="check" size={12} />
          </span>
        </button>
      ))}
    </div>
  </div>

  <div class="panel-section">
    <span class="section-label">Mode</span>
    <div class="mode-toggle">
      <button class="mode-btn" data-mode="light" aria-label="Light mode">
        <Icon name="sun" size={16} />
        <span>Light</span>
      </button>
      <button class="mode-btn" data-mode="dark" aria-label="Dark mode">
        <Icon name="moon" size={16} />
        <span>Dark</span>
      </button>
    </div>
  </div>
</div>

<style>
  .personalize-trigger {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 1000;
  }

  .trigger-btn {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--text-primary) 6%, var(--bg));
    color: var(--text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease, transform 0.15s ease;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .trigger-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: scale(1.05);
  }

  .trigger-btn :global(svg) {
    display: block;
  }

  .personalize-panel {
    position: fixed;
    bottom: 80px;
    right: 24px;
    z-index: 1001;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
    min-width: 220px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    opacity: 0;
    transform: translateY(8px) scale(0.96);
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .personalize-panel.open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .panel-title {
    font-size: 1.18rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .panel-close {
    background: none;
    border: none;
    color: var(--text-tertiary);
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s ease;
  }

  .panel-close:hover {
    color: var(--text-primary);
  }

  .panel-close :global(svg) {
    display: block;
  }

  .panel-section {
    margin-bottom: 16px;
  }

  .panel-section:last-child {
    margin-bottom: 0;
  }

  .section-label {
    display: block;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: 10px;
  }

  .theme-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
  }

  .theme-swatch {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: 2px solid transparent;
    cursor: pointer;
    position: relative;
    transition: border-color 0.15s ease, transform 0.15s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .theme-swatch:hover {
    transform: scale(1.1);
  }

  .theme-swatch.active {
    border-color: var(--text-primary);
  }

  .swatch-gradient {
    background-size: 100% 100%;
  }

  .swatch-check {
    display: none;
    color: white;
    mix-blend-mode: difference;
  }

  .theme-swatch.active .swatch-check {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .swatch-check :global(svg) {
    display: block;
  }

  .mode-toggle {
    display: flex;
    gap: 8px;
  }

  .mode-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 8px 12px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-tertiary);
    cursor: pointer;
    font-size: 1rem;
    font-family: var(--font-sans);
    transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
  }

  .mode-btn:hover {
    border-color: var(--text-tertiary);
    color: var(--text-secondary);
  }

  .mode-btn.active {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    color: var(--accent);
  }

  .mode-btn :global(svg) {
    display: block;
  }

  @media (max-width: 480px) {
    .personalize-trigger {
      bottom: 16px;
      right: 16px;
    }

    .personalize-panel {
      bottom: 72px;
      right: 16px;
      left: 16px;
      min-width: auto;
    }
  }
</style>

<script is:inline>
  // Theme definitions (must match server-side)
  const themes = {
    ember:    { light: { accent: '#c2410c', accentHover: '#a83608' }, dark: { accent: '#fb923c', accentHover: '#f97316' } },
    electric: { light: { accent: '#2563eb', accentHover: '#1d4ed8' }, dark: { accent: '#60a5fa', accentHover: '#3b82f6' } },
    violet:   { light: { accent: '#7c3aed', accentHover: '#6d28d9' }, dark: { accent: '#a78bfa', accentHover: '#8b5cf6' } },
    emerald:  { light: { accent: '#059669', accentHover: '#047857' }, dark: { accent: '#34d399', accentHover: '#10b981' } },
    rose:     { light: { accent: '#db2777', accentHover: '#be185d' }, dark: { accent: '#f472b6', accentHover: '#ec4899' } },
    sunset:   { light: { accent: '#f97316', accentHover: '#ea580c', gradientFrom: '#f97316', gradientTo: '#ec4899' }, dark: { accent: '#fb923c', accentHover: '#f97316', gradientFrom: '#fb923c', gradientTo: '#f472b6' } },
    aurora:   { light: { accent: '#06b6d4', accentHover: '#0891b2', gradientFrom: '#06b6d4', gradientTo: '#8b5cf6' }, dark: { accent: '#22d3ee', accentHover: '#06b6d4', gradientFrom: '#22d3ee', gradientTo: '#a78bfa' } },
    lava:     { light: { accent: '#ef4444', accentHover: '#dc2626', gradientFrom: '#ef4444', gradientTo: '#f59e0b' }, dark: { accent: '#f87171', accentHover: '#ef4444', gradientFrom: '#f87171', gradientTo: '#fbbf24' } },
  };

  function applyTheme(themeId, mode) {
    const theme = themes[themeId];
    if (!theme) return;
    const colors = theme[mode] || theme.dark;
    const root = document.documentElement;

    root.setAttribute('data-theme', themeId);
    root.setAttribute('data-mode', mode);

    root.style.setProperty('--accent', colors.accent);
    root.style.setProperty('--accent-hover', colors.accentHover);

    if (colors.gradientFrom) {
      root.style.setProperty('--accent-gradient', `linear-gradient(135deg, ${colors.gradientFrom}, ${colors.gradientTo})`);
      root.style.setProperty('--accent-gradient-from', colors.gradientFrom);
      root.style.setProperty('--accent-gradient-to', colors.gradientTo);
    } else {
      root.style.setProperty('--accent-gradient', colors.accent);
      root.style.setProperty('--accent-gradient-from', colors.accent);
      root.style.setProperty('--accent-gradient-to', colors.accent);
    }

    // Scroll progress bar
    const progressBar = document.getElementById('scroll-progress');
    if (progressBar) {
      progressBar.style.background = colors.gradientFrom
        ? `linear-gradient(90deg, ${colors.gradientFrom}, ${colors.gradientTo})`
        : `linear-gradient(90deg, ${colors.accent}, ${colors.accentHover})`;
    }

    localStorage.setItem('theme', themeId);
    localStorage.setItem('mode', mode);

    // Update swatches
    document.querySelectorAll('.theme-swatch').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.themeId === themeId);
    });
    document.querySelectorAll('.mode-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.mode === mode);
    });
  }

  // Initialize
  const storedTheme = localStorage.getItem('theme') || 'ember';
  const storedMode = localStorage.getItem('mode') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
  applyTheme(storedTheme, storedMode);

  // Toggle panel
  const trigger = document.getElementById('trigger-btn');
  const panel = document.getElementById('personalize-panel');
  const close = document.getElementById('panel-close');

  trigger.addEventListener('click', () => {
    panel.classList.toggle('open');
  });

  close.addEventListener('click', () => {
    panel.classList.remove('open');
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!panel.contains(e.target) && !trigger.contains(e.target)) {
      panel.classList.remove('open');
    }
  });

  // Theme swatches
  document.querySelectorAll('.theme-swatch').forEach(btn => {
    btn.addEventListener('click', () => {
      const themeId = btn.dataset.themeId;
      const currentMode = document.documentElement.getAttribute('data-mode') || 'light';
      applyTheme(themeId, currentMode);
    });
  });

  // Mode buttons
  document.querySelectorAll('.mode-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const mode = btn.dataset.mode;
      const currentTheme = document.documentElement.getAttribute('data-theme') || 'ember';
      applyTheme(currentTheme, mode);
    });
  });
</script>